<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Philadelphus.Presentation.Avalonia.Views.Controls.StoragesCreation">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition />
            <ColumnDefinition />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="30" />
            <RowDefinition Height="30" />
            <RowDefinition Height="30" />
            <RowDefinition Height="30" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" Text="Наименование" Margin="1" VerticalAlignment="Center" />
        <TextBox Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2" Text="{Binding Name}" Margin="1" />
        <TextBlock Grid.Row="1" Grid.Column="0" Text="Описание" Margin="1" VerticalAlignment="Center" />
        <TextBox Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" Text="{Binding Description}" Margin="1" />
        <TextBlock Grid.Row="2" Grid.Column="0" Text="Строка подключения" Margin="1" VerticalAlignment="Center" />
        <ComboBox Grid.Row="2" Grid.Column="1" Margin="1" HorizontalAlignment="Stretch"
                  ItemsSource="{Binding ConnectionStringsContainers}"
                  SelectedItem="{Binding SelectedConnectionStringsContainer}">
            <ComboBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding Uuid}" />
                        <TextBlock Text=". Провайдер: " />
                        <TextBlock Text="{Binding ProviderName}" />
                        <TextBlock Text=". Строка подключения: " />
                        <TextBlock Text="{Binding ConnectionString}" />
                    </StackPanel>
                </DataTemplate>
            </ComboBox.ItemTemplate>
        </ComboBox>
        <Button Grid.Row="2" Grid.Column="2" Command="{Binding OpenConnectionStringsSettingsControlCommand}" Content="Открыть настройки строк подключения" Margin="1" />
        <Button Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="3" Command="{Binding CreateAndSaveDataStorageCommand}" Content="Создать и сохранить" Margin="1" />
    </Grid>
</UserControl>

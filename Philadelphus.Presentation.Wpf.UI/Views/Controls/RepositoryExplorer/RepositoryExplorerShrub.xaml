<UserControl x:Class="Philadelphus.Presentation.Wpf.UI.Views.Controls.RepositoryExplorer.RepositoryExplorerShrub"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Philadelphus.Presentation.Wpf.UI.Views.Controls.RepositoryExplorer"
             xmlns:converters="clr-namespace:Philadelphus.Presentation.Wpf.UI.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <converters:StateToColorConverter x:Key="stateToColorConverter"/>
    </UserControl.Resources>
    <Grid>
        <TreeView Name="MainTreeView"
                  DataContext="{Binding PhiladelphusRepositoryVM}" 
                  ItemsSource="{Binding Childs}" 
                  SelectedItemChanged="MainTreeView_SelectedItemChanged">

            <TreeView.ItemTemplate>
                <HierarchicalDataTemplate ItemsSource="{Binding Path=ChildNodes}">
                    <Grid Margin="1"
                          Background="Snow"
                          ToolTip="{Binding State, Converter={StaticResource enumDisplayAttributeConverter}, ConverterParameter=Description}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="4"></ColumnDefinition>
                            <ColumnDefinition Width="*"></ColumnDefinition>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"></RowDefinition>
                            <RowDefinition Height="Auto"></RowDefinition>
                        </Grid.RowDefinitions>

                        <Rectangle Grid.RowSpan="2"
                                   Grid.Column="0"
                                   Fill="{Binding State, Converter={StaticResource stateToColorConverter}}" />

                        <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal">
                            <Image Width="24" 
                                   Height="24" 
                                   Margin="10,0,10,0" 
                                   Source="{Binding ., Converter={StaticResource iconConverter}}"></Image>
                            <StackPanel Margin="0,2,10,2">
                                <TextBlock>
                                                <Run Text="Наименование: " FontSize="10" FontWeight="Light" Foreground="LightSlateGray" />
                                                <Run Text="{Binding Name}" FontStyle="Italic"  Foreground="Black"/>
                                </TextBlock>
                                <TextBlock>
                                                <Run Text="Uuid: " FontSize="10" FontWeight="Light" Foreground="LightSlateGray" />
                                                <Run Text="{Binding Uuid, Mode=OneWay}" FontStyle="Italic"  Foreground="Black"/>
                                </TextBlock>
                            </StackPanel>
                        </StackPanel>
                        <Rectangle Grid.Row="1" Grid.ColumnSpan="2" HorizontalAlignment="Stretch" VerticalAlignment="Center" Fill="Gray" Height="0.25"/>
                    </Grid>
                </HierarchicalDataTemplate>
            </TreeView.ItemTemplate>
            <TreeView.Resources>
                <!--<HierarchicalDataTemplate DataType="{x:Type mainentities:TreeRoot}" ItemsSource="{Binding Childs}">
                                <StackPanel Orientation="Horizontal">
                                    <Image Width="24" Height="24" Margin="10,0,10,0" Source="C:\Users\MeleychukSV\Downloads\icons8_icon_repository.png" />
                                    <TextBlock Text="{Binding Name}" />
                                </StackPanel>
                            </HierarchicalDataTemplate>
                            <HierarchicalDataTemplate DataType="{x:Type mainentities:TreeNode}" ItemsSource="{Binding Childs}" >
                                <StackPanel Orientation="Horizontal">
                                    <Image Width="16" Height="16" Margin="3,0" Source="C:\Users\MeleychukSV\Downloads\Flaticon_icon_node.png" />
                                    <TextBlock Text="{Binding Name}" />
                                </StackPanel>
                            </HierarchicalDataTemplate>
                            <HierarchicalDataTemplate DataType="{x:Type mainentities:TreeLeave}" ItemsSource="{Binding Childs}" >
                                <StackPanel Orientation="Horizontal">
                                    <Image Width="16" Height="16" Margin="3,0" Source="C:\Users\MeleychukSV\Downloads\Flaticon_icon_leave.png" />
                                    <TextBlock Text="{Binding Name}" />
                                </StackPanel>
                            </HierarchicalDataTemplate>-->
            </TreeView.Resources>
        </TreeView>

    </Grid>
</UserControl>

    </UserControl.DataTemplates>

    <Panel>
        <ContentControl Content="{Binding}"
                        IsVisible="{Binding Converter={x:Static ac:ObjectConverters.IsNotNull}}" />
        <Border IsVisible="{Binding Converter={x:Static ac:ObjectConverters.IsNull}}"
                Background="{DynamicResource SystemControlBackgroundAltHighBrush}" Padding="10" CornerRadius="8"
                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}" BorderThickness="1">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="4">
                <TextBlock Text="Элемент не выбран" FontSize="16" FontWeight="SemiBold" HorizontalAlignment="Center" />
                <TextBlock Text="Выберите элемент для просмотра свойств" FontStyle="Italic" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" HorizontalAlignment="Center" TextAlignment="Center" />
            </StackPanel>
        </Border>
    </Panel>
</UserControl>

<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Philadelphus.Presentation.Avalonia.Views.Controls.CollectionControls.ListBoxes.RepositoryHeadersListBox">
    <Grid>
        <ListBox Margin="1" BorderBrush="LightGray" BorderThickness="1"
                 ItemsSource="{Binding $parent[UserControl].RepositoryHeadersItemsSource}"
                 SelectedItem="{Binding $parent[UserControl].RepositoryHeadersSelectedItem, Mode=TwoWay}">
            <ListBox.Styles>
                <Style Selector="ListBoxItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                </Style>
            </ListBox.Styles>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition />
                            <RowDefinition />
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" MinWidth="300" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition />
                                <RowDefinition />
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Column="0" Grid.Row="0" Height="20" VerticalAlignment="Center" Margin="1">
                                <Run Text="Репозиторий: " FontWeight="Light" Foreground="LightSlateGray" />
                                <Run Text="{Binding Name, Mode=OneWay}" FontStyle="Italic" />
                                <Run Text="   " />
                                <Run Text="UUID:" FontWeight="Light" Foreground="LightSlateGray" />
                                <Run Text="{Binding Uuid, Mode=OneWay}" FontStyle="Italic" />
                            </TextBlock>
                            <TextBlock Grid.Column="0" Grid.Row="1" Height="20" VerticalAlignment="Center" Margin="1">
                                <Run Text="Хранилище: " FontWeight="Light" Foreground="LightSlateGray" />
                                <Run Text="{Binding OwnDataStorageName, Mode=OneWay}" FontStyle="Italic" />
                                <Run Text="   " />
                                <Run Text="UUID:" FontWeight="Light" Foreground="LightSlateGray" />
                                <Run Text="{Binding OwnDataStorageUuid, Mode=OneWay}" FontStyle="Italic" />
                            </TextBlock>
                            <TextBlock Grid.Column="2" Grid.Row="0" Grid.RowSpan="100" Height="20" VerticalAlignment="Center" Margin="5,2,5,2">
                                <Run Text="Доступность:" FontWeight="Light" Foreground="LightSlateGray" />
                                <Run Text="{Binding IsPhiladelphusRepositoryAvailable, Mode=OneWay}" FontWeight="Bold" Foreground="{Binding IsPhiladelphusRepositoryAvailable, Mode=OneWay, Converter={StaticResource booleanToColorConverter}}" />
                            </TextBlock>
                            <TextBlock Grid.Column="3" Grid.Row="0" Grid.RowSpan="100" Height="20" VerticalAlignment="Center" Margin="5,2,5,2">
                                <Run Text="Последний запуск: " FontWeight="Light" Foreground="LightSlateGray" />
                                <Run Text="{Binding LastOpening, Mode=OneWay, Converter={StaticResource lastLaunchToDaysAgoConverter}}" />
                            </TextBlock>
                            <ToggleButton Grid.Column="4" Grid.Row="0" Grid.RowSpan="100" IsChecked="{Binding IsFavorite}" ToolTip.Tip="Избранное" Margin="5,2,5,2" Width="30" Height="30" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="☆" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="25" />
                            </ToggleButton>
                        </Grid>
                        <Rectangle Grid.Row="1" HorizontalAlignment="Stretch" VerticalAlignment="Center" Fill="Gray" Height="1" />
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</UserControl>

<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:localControls="clr-namespace:Philadelphus.Presentation.Avalonia.Controls"
             x:Class="Philadelphus.Presentation.Avalonia.Views.Controls.RepositoryExplorer.RepositoryExplorerShrub">
    <Grid>
        <TreeView Name="MainTreeView"
                  DataContext="{Binding PhiladelphusRepositoryVM}"
                  ItemsSource="{Binding Childs}"
                  SelectionChanged="MainTreeView_SelectionChanged">
            <TreeView.ItemTemplate>
                <TreeDataTemplate ItemsSource="{Binding ChildNodes}">
                    <Grid Margin="1"
                          ColumnDefinitions="4,*"
                          RowDefinitions="*,Auto"
                          ToolTip.Tip="{Binding State, Converter={StaticResource enumDisplayAttributeConverter}, ConverterParameter=Description}">
                        <Rectangle Grid.RowSpan="2"
                                   Grid.Column="0"
                                   Fill="{Binding State, Converter={StaticResource stateToColorConverter}}" />
                        <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal">
                            <localControls:ThemedSvg Icon="{Binding Converter={StaticResource iconNameConverter}}"
                                                     Width="24" Height="24" Margin="10,0,10,0" />
                            <StackPanel Margin="0,2,10,2">
                                <TextBlock>
                                    <Run Text="Наименование: " FontSize="10" FontWeight="Light" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                                    <Run Text="{Binding Name}" FontStyle="Italic" />
                                </TextBlock>
                                <TextBlock>
                                    <Run Text="Uuid: " FontSize="10" FontWeight="Light" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                                    <Run Text="{Binding Uuid, Mode=OneWay}" FontStyle="Italic" />
                                </TextBlock>
                            </StackPanel>
                        </StackPanel>
                        <Rectangle Grid.Row="1" Grid.ColumnSpan="2" HorizontalAlignment="Stretch" VerticalAlignment="Center" Fill="{DynamicResource SystemControlForegroundBaseLowBrush}" Height="0.25" />
                    </Grid>
                </TreeDataTemplate>
            </TreeView.ItemTemplate>
        </TreeView>
    </Grid>
</UserControl>

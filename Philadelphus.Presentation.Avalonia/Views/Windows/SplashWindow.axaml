<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Philadelphus.Presentation.Avalonia.Views.Windows.SplashWindow"
        Width="420"
        Height="240"
        CanResize="False"
        SystemDecorations="None"
        ShowInTaskbar="False"
        Topmost="True"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        TransparencyLevelHint="Transparent">

    <!-- Простой тема-зависимый сплэш: логотип + название + индикатор.
         Цвета берутся из ресурсов Fluent, поэтому окно следует светлой/тёмной теме.
         Окно прозрачное — видна только скруглённая рамка (без «фона за углами»). -->
    <Border Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
            BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
            BorderThickness="1"
            CornerRadius="8">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="14">
            <Image Source="/Assets/Icons/philadelphus_logo_64.png"
                   Width="64" Height="64" HorizontalAlignment="Center" />
            <TextBlock Text="Чубушник"
                       FontSize="34" FontWeight="SemiBold"
                       HorizontalAlignment="Center" />
            <TextBlock x:Name="StatusText"
                       Text="Подготовка запуска..."
                       Width="280"
                       TextAlignment="Center"
                       TextWrapping="Wrap"
                       FontSize="13"
                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                       HorizontalAlignment="Center" />
            <ProgressBar IsIndeterminate="True" Width="240" Height="4" Margin="0,4,0,0" />
            <TextBlock x:Name="ElapsedText"
                       Text=" "
                       FontSize="11"
                       Foreground="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                       HorizontalAlignment="Center" />
        </StackPanel>
    </Border>
</Window>

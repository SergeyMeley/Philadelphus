<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:detail="clr-namespace:Philadelphus.Presentation.Avalonia.Views.Controls.DetailedInformationGrids"
        x:Class="Philadelphus.Presentation.Avalonia.Views.Windows.DetailsWindow"
        Title="{Binding Content.Name}"
        Width="640"
        Height="480"
        WindowStartupLocation="CenterOwner">
    <Grid>
        <detail:UniversalDetails DataContext="{Binding Content}" />
    </Grid>
</Window>

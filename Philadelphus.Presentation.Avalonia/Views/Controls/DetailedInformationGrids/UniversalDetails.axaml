                </TabItem>
                <TabItem Classes="compact" Header="Хранилище">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <local:DataStorageDetails DataContext="{Binding StorageVM}" IsReadOnly="True" />
                    </ScrollViewer>
                </TabItem>
                <TabItem Classes="compact" Header="Аудит">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <local:AuditInfoDetails DataContext="{Binding AuditInfo}" />
                    </ScrollViewer>
                </TabItem>
            </TabControl>
        </DataTemplate>

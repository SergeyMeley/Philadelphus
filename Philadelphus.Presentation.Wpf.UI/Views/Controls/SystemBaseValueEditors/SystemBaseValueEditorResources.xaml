<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:enums="clr-namespace:Philadelphus.Core.Domain.Entities.Enums;assembly=Philadelphus.Core.Domain">
    <!-- Общие компактные стили редакторов значения базового листа.
         Они намеренно близки к существующим стандартным контролам, чтобы типизированный редактор
         не выбивался из текущего плотного интерфейса обозревателя и таблиц. -->
    <Style x:Key="SystemBaseValueTextBoxStyle" TargetType="TextBox">
        <Setter Property="Height" Value="24" />
        <Setter Property="MinWidth" Value="180" />
        <Setter Property="Margin" Value="1" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Padding" Value="4,1" />
    </Style>

    <Style x:Key="SystemBaseValueDatePickerStyle" TargetType="DatePicker">
        <Setter Property="Height" Value="24" />
        <Setter Property="MinWidth" Value="180" />
        <Setter Property="Margin" Value="1" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <!-- STRING, OBJECT, BOOL и неподдержанные специальным шаблоном типы редактируются как строка.
         Доменная модель и политики остаются последним рубежом проверки допустимости значения. -->
    <DataTemplate x:Key="SystemBaseStringValueTemplate">
        <TextBox Style="{StaticResource SystemBaseValueTextBoxStyle}"
                 Text="{Binding StringValue, UpdateSourceTrigger=PropertyChanged}" />
    </DataTemplate>

    <!-- Для чисел оставляем TextBox, а не spinner: пользователь может вводить промежуточные состояния
         вроде "-" или "1.", после чего доменная валидация решит, принимать значение или нет. -->
    <DataTemplate x:Key="SystemBaseNumericValueTemplate">
        <TextBox Style="{StaticResource SystemBaseValueTextBoxStyle}"
                 Text="{Binding StringValue, UpdateSourceTrigger=PropertyChanged}"
                 HorizontalContentAlignment="Right" />
    </DataTemplate>

    <!-- DatePicker редактирует только дату, поэтому DATETIME ниже разбит на дату, время и offset. -->
    <DataTemplate x:Key="SystemBaseDateValueTemplate">
        <DatePicker Style="{StaticResource SystemBaseValueDatePickerStyle}"
                    SelectedDate="{Binding DateValue, UpdateSourceTrigger=PropertyChanged}" />
    </DataTemplate>

    <!-- В WPF нет штатного TimePicker, поэтому TIME пока остается коротким текстовым полем. -->
    <DataTemplate x:Key="SystemBaseTimeValueTemplate">
        <TextBox Style="{StaticResource SystemBaseValueTextBoxStyle}"
                 Text="{Binding TimeValue, UpdateSourceTrigger=PropertyChanged}"
                 MaxLength="8"
                 ToolTip="HH:mm:ss" />
    </DataTemplate>

    <!-- DATETIME хранится строкой DateTimeOffset-совместимого формата:
         дата + время + смещение, например 2026-05-21T10:15:30+03:00. -->
    <DataTemplate x:Key="SystemBaseDateTimeValueTemplate">
        <StackPanel Orientation="Horizontal">
            <DatePicker Style="{StaticResource SystemBaseValueDatePickerStyle}"
                        MinWidth="150"
                        SelectedDate="{Binding DateTimeDateValue, UpdateSourceTrigger=PropertyChanged}" />
            <TextBox Style="{StaticResource SystemBaseValueTextBoxStyle}"
                     MinWidth="80"
                     Text="{Binding DateTimeTimeValue, UpdateSourceTrigger=PropertyChanged}"
                     MaxLength="8"
                     ToolTip="HH:mm:ss" />
            <TextBox Style="{StaticResource SystemBaseValueTextBoxStyle}"
                     MinWidth="64"
                     Text="{Binding DateTimeOffsetValue, UpdateSourceTrigger=PropertyChanged}"
                     MaxLength="6"
                     ToolTip="+03:00" />
        </StackPanel>
    </DataTemplate>

    <!-- Общий selector для редактора системного значения.
         Контент должен предоставлять SystemBaseType и свойства, используемые выбранным шаблоном
         (StringValue, DateValue, TimeValue, DateTimeDateValue, DateTimeTimeValue, DateTimeOffsetValue). -->
    <Style x:Key="SystemBaseValueEditorContentControlStyle" TargetType="ContentControl">
        <Setter Property="ContentTemplate" Value="{StaticResource SystemBaseStringValueTemplate}" />
        <Style.Triggers>
            <DataTrigger Binding="{Binding Content.SystemBaseType, RelativeSource={RelativeSource Self}}" Value="{x:Static enums:SystemBaseType.INTEGER}">
                <Setter Property="ContentTemplate" Value="{StaticResource SystemBaseNumericValueTemplate}" />
            </DataTrigger>
            <DataTrigger Binding="{Binding Content.SystemBaseType, RelativeSource={RelativeSource Self}}" Value="{x:Static enums:SystemBaseType.NUMERIC}">
                <Setter Property="ContentTemplate" Value="{StaticResource SystemBaseNumericValueTemplate}" />
            </DataTrigger>
            <DataTrigger Binding="{Binding Content.SystemBaseType, RelativeSource={RelativeSource Self}}" Value="{x:Static enums:SystemBaseType.FLOAT}">
                <Setter Property="ContentTemplate" Value="{StaticResource SystemBaseNumericValueTemplate}" />
            </DataTrigger>
            <DataTrigger Binding="{Binding Content.SystemBaseType, RelativeSource={RelativeSource Self}}" Value="{x:Static enums:SystemBaseType.MONEY}">
                <Setter Property="ContentTemplate" Value="{StaticResource SystemBaseNumericValueTemplate}" />
            </DataTrigger>
            <DataTrigger Binding="{Binding Content.SystemBaseType, RelativeSource={RelativeSource Self}}" Value="{x:Static enums:SystemBaseType.DATE}">
                <Setter Property="ContentTemplate" Value="{StaticResource SystemBaseDateValueTemplate}" />
            </DataTrigger>
            <DataTrigger Binding="{Binding Content.SystemBaseType, RelativeSource={RelativeSource Self}}" Value="{x:Static enums:SystemBaseType.TIME}">
                <Setter Property="ContentTemplate" Value="{StaticResource SystemBaseTimeValueTemplate}" />
            </DataTrigger>
            <DataTrigger Binding="{Binding Content.SystemBaseType, RelativeSource={RelativeSource Self}}" Value="{x:Static enums:SystemBaseType.DATETIME}">
                <Setter Property="ContentTemplate" Value="{StaticResource SystemBaseDateTimeValueTemplate}" />
            </DataTrigger>
        </Style.Triggers>
    </Style>
</ResourceDictionary>

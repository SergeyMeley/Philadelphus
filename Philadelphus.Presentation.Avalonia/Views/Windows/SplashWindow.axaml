<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Philadelphus.Presentation.Avalonia.Views.Windows.SplashWindow"
        Width="460"
        Height="280"
        CanResize="False"
        SystemDecorations="None"
        ShowInTaskbar="False"
        Topmost="True"
        WindowStartupLocation="CenterScreen">

    <Window.Background>
        <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
            <GradientStop Offset="0" Color="#13203A" />
            <GradientStop Offset="1" Color="#0A0F1C" />
        </LinearGradientBrush>
    </Window.Background>

    <Window.Styles>
        <!-- Бесконечное вращение индикатора -->
        <Style Selector="Ellipse.arc">
            <Style.Animations>
                <Animation Duration="0:0:1.0" IterationCount="Infinite">
                    <KeyFrame Cue="0%">
                        <Setter Property="RotateTransform.Angle" Value="0" />
                    </KeyFrame>
                    <KeyFrame Cue="100%">
                        <Setter Property="RotateTransform.Angle" Value="360" />
                    </KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>

        <!-- Мягкая пульсация названия -->
        <Style Selector="TextBlock.title">
            <Style.Animations>
                <Animation Duration="0:0:1.8" IterationCount="Infinite">
                    <KeyFrame Cue="0%">
                        <Setter Property="Opacity" Value="0.7" />
                    </KeyFrame>
                    <KeyFrame Cue="50%">
                        <Setter Property="Opacity" Value="1.0" />
                    </KeyFrame>
                    <KeyFrame Cue="100%">
                        <Setter Property="Opacity" Value="0.7" />
                    </KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>
    </Window.Styles>

    <Border BorderBrush="#22344B" BorderThickness="1">
        <Grid RowDefinitions="*,Auto,Auto,*">
            <StackPanel Grid.Row="1" HorizontalAlignment="Center" Spacing="6">
                <TextBlock Classes="title"
                           Text="Чубушник"
                           FontSize="42"
                           FontWeight="Bold"
                           Foreground="#E8EEF7"
                           HorizontalAlignment="Center" />
                <TextBlock Text="Загрузка…"
                           FontSize="14"
                           Foreground="#7E93AD"
                           HorizontalAlignment="Center" />
            </StackPanel>

            <Grid Grid.Row="2" Width="52" Height="52" Margin="0,30,0,0" HorizontalAlignment="Center">
                <!-- Дорожка -->
                <Ellipse Width="44" Height="44" Stroke="#22344B" StrokeThickness="4" />
                <!-- Вращающийся сегмент -->
                <Ellipse Classes="arc"
                         Width="44"
                         Height="44"
                         Stroke="#4C9AFF"
                         StrokeThickness="4"
                         StrokeLineCap="Round"
                         StrokeDashArray="9,27"
                         RenderTransformOrigin="50%,50%" />
            </Grid>
        </Grid>
    </Border>
</Window>

<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Philadelphus.Presentation.Avalonia.Views.Controls.DetailedInformationGrids.PhiladelphusRepositoryDetails">
    <StackPanel Spacing="12">
        <HeaderedContentControl Header="Хранилища по умолчанию">
            <Grid ColumnDefinitions="90,*,Auto"
                  RowDefinitions="Auto,Auto"
                  ColumnSpacing="8"
                  RowSpacing="6">
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Кустарник" VerticalAlignment="Center" />
                <ComboBox Grid.Row="0" Grid.Column="1"
                          ItemsSource="{Binding ShrubMembersDefaultDataStorages}"
                          SelectedItem="{Binding DefaultShrubMembersDataStorage, Mode=TwoWay}"
                          PlaceholderText="Не задано">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Name}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
                <Button Grid.Row="0" Grid.Column="2"
                        Width="28" Height="28" Padding="0"
                        Content="x"
                        Command="{Binding ClearDefaultShrubMembersDataStorageCommand}"
                        ToolTip.Tip="Очистить хранилище по умолчанию" />

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Отчеты" VerticalAlignment="Center" />
                <ComboBox Grid.Row="1" Grid.Column="1"
                          ItemsSource="{Binding ReportsDefaultDataStorages}"
                          SelectedItem="{Binding DefaultReportsDataStorage, Mode=TwoWay}"
                          PlaceholderText="Не задано">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Name}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
                <Button Grid.Row="1" Grid.Column="2"
                        Width="28" Height="28" Padding="0"
                        Content="x"
                        Command="{Binding ClearDefaultReportsDataStorageCommand}"
                        ToolTip.Tip="Очистить хранилище по умолчанию" />
            </Grid>
        </HeaderedContentControl>

        <HeaderedContentControl Header="Возможные хранилища">
            <Grid RowDefinitions="Auto,*" RowSpacing="8">
                <Grid Grid.Row="0" ColumnDefinitions="*,Auto" ColumnSpacing="8">
                    <ComboBox x:Name="storageToAddComboBox"
                              Grid.Column="0"
                              ItemsSource="{Binding AllDataStorages}"
                              PlaceholderText="Выберите хранилище">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Name}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <Button Grid.Column="1"
                            Width="28" Height="28" Padding="0"
                            Content="+"
                            Command="{Binding AddAvailableDataStorageCommand}"
                            CommandParameter="{Binding #storageToAddComboBox.SelectedItem}"
                            ToolTip.Tip="Добавить возможное хранилище" />
                </Grid>

                <DataGrid Grid.Row="1"
                          ItemsSource="{Binding DataStorages}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          MinHeight="120"
                          MaxHeight="260">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Наименование"
                                            Binding="{Binding Name}"
                                            Width="2*" />
                        <DataGridTextColumn Header="Uuid"
                                            Binding="{Binding Uuid}"
                                            Width="3*" />
                        <DataGridTemplateColumn Width="42" CanUserSort="False">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Width="28" Height="28" Padding="0"
                                            Content="x"
                                            Command="{Binding $parent[UserControl].DataContext.RemoveAvailableDataStorageCommand}"
                                            CommandParameter="{Binding}"
                                            ToolTip.Tip="Удалить возможное хранилище" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </HeaderedContentControl>
    </StackPanel>
</UserControl>

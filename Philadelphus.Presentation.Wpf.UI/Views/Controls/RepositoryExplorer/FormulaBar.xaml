<UserControl x:Class="Philadelphus.Presentation.Wpf.UI.Views.Controls.RepositoryExplorer.FormulaBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:behaviors="clr-namespace:Philadelphus.Presentation.Wpf.UI.Behaviors"
             mc:Ignorable="d"
             d:DesignHeight="30"
             d:DesignWidth="800">
    <Border BorderBrush="LightGray"
            BorderThickness="0,0,0,1"
            Padding="2"
            Margin="0,0,0,2"
            Background="#FFF7F7F7">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="160" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBox Grid.Column="0"
                     Text="{Binding FormulaBarAddress, Mode=OneWay}"
                     IsReadOnly="True"
                     Height="25"
                     Margin="1"
                     VerticalContentAlignment="Center"
                     Background="White"
                     ToolTip="Адрес ячейки" />
            <Button Grid.Column="1"
                    Content="{StaticResource imageApproval64}"
                    Command="{Binding ApplyFormulaBarCommand}"
                    Height="25"
                    Width="25"
                    Margin="1"
                    Background="Transparent"
                    ToolTip="Применить формулу" />
            <Button Grid.Column="2"
                    Content="{StaticResource imageReturn}"
                    Command="{Binding CancelFormulaBarCommand}"
                    Height="25"
                    Width="25"
                    Margin="1"
                    Background="Transparent"
                    ToolTip="Отменить редактирование формулы" />
            <Button Grid.Column="3"
                    Content="{StaticResource imageOpen}"
                    Command="{Binding OpenFormulaEditorFromFormulaBarCommand}"
                    Height="25"
                    Width="25"
                    Margin="1"
                    Background="Transparent"
                    ToolTip="Открыть редактор формул" />
            <TextBox Grid.Column="4"
                     Text="{Binding FormulaBarText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     IsEnabled="{Binding IsFormulaBarEnabled}"
                     behaviors:FormulaBarTextBoxBehavior.Track="True"
                     behaviors:FormulaBarTextBoxBehavior.IsEditing="{Binding IsFormulaBarEditing, Mode=TwoWay}"
                     behaviors:FormulaBarTextBoxBehavior.CaretIndex="{Binding FormulaBarCaretIndex, Mode=TwoWay}"
                     behaviors:FormulaBarTextBoxBehavior.SelectionStart="{Binding FormulaBarSelectionStart, Mode=TwoWay}"
                     behaviors:FormulaBarTextBoxBehavior.SelectionLength="{Binding FormulaBarSelectionLength, Mode=TwoWay}"
                     Height="25"
                     Margin="1"
                     VerticalContentAlignment="Center">
                <TextBox.InputBindings>
                    <KeyBinding Key="Enter" Command="{Binding ApplyFormulaBarCommand}" />
                    <KeyBinding Key="Escape" Command="{Binding CancelFormulaBarCommand}" />
                </TextBox.InputBindings>
            </TextBox>
        </Grid>
    </Border>
</UserControl>

<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:beh="clr-namespace:Philadelphus.Presentation.Avalonia.Behaviors"
        x:Class="Philadelphus.Presentation.Avalonia.Views.Windows.AttributeValuesCollectionWindow"
        Title="Список значений атрибута"
        Width="1000"
        Height="650"
        MinWidth="700"
        MinHeight="400"
        WindowStartupLocation="CenterOwner">
    <Grid RowDefinitions="Auto,*" Margin="8">
        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock Text="Атрибут: " FontWeight="SemiBold" />
            <TextBlock Text="{Binding Attribute.Name}" />
        </StackPanel>

        <DataGrid Grid.Row="1"
                  AutoGenerateColumns="False"
                  ItemsSource="{Binding Rows}"
                  beh:DataGridColumnsBehavior.ColumnsSource="{Binding Columns}" />
    </Grid>
</Window>

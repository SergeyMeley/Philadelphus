<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ctrls="clr-namespace:Philadelphus.Presentation.Avalonia.Views.Controls"
             x:Class="Philadelphus.Presentation.Avalonia.Views.Controls.RepositoryOpen">
    <Grid>
        <TabControl>
            <TabItem Header="Избранные и недавние">
                <ctrls:FavoriteAndLastRepositoryHeaders />
            </TabItem>
            <TabItem Header="Доступные">
                <ctrls:AvailableRepositoryHeaders />
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>

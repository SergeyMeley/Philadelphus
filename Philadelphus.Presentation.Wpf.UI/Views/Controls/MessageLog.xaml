<UserControl x:Class="Philadelphus.Presentation.Wpf.UI.Views.Controls.MessageLog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Philadelphus.Presentation.Wpf.UI.Views.Controls"
             xmlns:converters="clr-namespace:Philadelphus.Presentation.Wpf.UI.Converters"
             mc:Ignorable="d">
    <UserControl.Resources>
        <converters:CriticalLevelToIconConverter x:Key="criticalLevelToIconConverter"/>
    </UserControl.Resources>
    <Grid>
        <Expander Header="Журнал сообщений" ExpandDirection="Down" Margin="1" IsExpanded="True">
            <Expander.HeaderTemplate>
                <DataTemplate>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="auto"/>
                            <ColumnDefinition Width="auto"/>
                            <ColumnDefinition Width="auto"/>
                            <ColumnDefinition Width="auto"/>
                            <ColumnDefinition Width="auto"/>
                            <ColumnDefinition Width="auto"/>
                            <ColumnDefinition Width="auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Журнал сообщений" VerticalAlignment="Center" Margin="1,0"></TextBlock>
                        <ToggleButton Grid.Column="1" 
                                      IsChecked="{Binding DataContext.IsOkMessagesVisible, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                      ToolTip="Отобразить / скрыть уведомления об успешном выполнении" 
                                      Padding="0" 
                                      Height="24"
                                      Margin="1,0">
                            <ToggleButton.ContentTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <ContentPresenter Grid.Column="0" Content="{StaticResource imageOk64_1}"></ContentPresenter>
                                        <TextBlock Grid.Column="1" 
                                                   Text="{Binding DataContext.OkMessagesCount, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                                   MinWidth="30"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"></TextBlock>
                                    </Grid>
                                </DataTemplate>
                            </ToggleButton.ContentTemplate>
                        </ToggleButton>
                        <ToggleButton Grid.Column="2" 
                                      IsChecked="{Binding DataContext.IsInfoMessagesVisible, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                      ToolTip="Отобразить / скрыть информационные сообщения" 
                                      Padding="0" 
                                      Height="24"
                                      Margin="1,0">
                            <ToggleButton.ContentTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <ContentPresenter Grid.Column="0" Content="{StaticResource imageInfo64_2}"></ContentPresenter>
                                        <TextBlock Grid.Column="1" 
                                                   Text="{Binding DataContext.InfoMessagesCount, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                                   MinWidth="30"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"></TextBlock>      
                                    </Grid>
                                </DataTemplate>
                            </ToggleButton.ContentTemplate>
                        </ToggleButton>
                        <ToggleButton Grid.Column="3" 
                                      IsChecked="{Binding DataContext.IsWarningMessagesVisible, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                      ToolTip="Отобразить / скрыть предупреждения" 
                                      Padding="0" 
                                      Height="24" 
                                      Margin="1,0">
                            <ToggleButton.ContentTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <ContentPresenter Grid.Column="0" Content="{StaticResource imageWarning64}"></ContentPresenter>
                                        <TextBlock Grid.Column="1" 
                                                   Text="{Binding DataContext.WarningMessagesCount, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                                   MinWidth="30"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"></TextBlock>
                                    </Grid>
                                </DataTemplate>
                            </ToggleButton.ContentTemplate>
                        </ToggleButton>
                        <ToggleButton Grid.Column="4"
                                      IsChecked="{Binding DataContext.IsErrorMessagesVisible, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                      ToolTip="Отобразить / скрыть сообщения об ошибках" 
                                      Padding="0"
                                      Height="24" 
                                      Margin="1,0">
                            <ToggleButton.ContentTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <ContentPresenter Grid.Column="0" Content="{StaticResource imageError64_3}"></ContentPresenter>
                                        <TextBlock Grid.Column="1" 
                                                   Text="{Binding DataContext.ErrorMessagesCount, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                                   MinWidth="30"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"></TextBlock>
                                    </Grid>
                                </DataTemplate>
                            </ToggleButton.ContentTemplate>
                        </ToggleButton>
                        <Button Grid.Column="5" 
                                Content="{StaticResource imageBroom64}" 
                                Command="{Binding DataContext.ClearMessageLogCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                ToolTip="Очистить журнал сообщений" 
                                Padding="0" 
                                Height="24" 
                                Margin="1,0"></Button>
                        <Button Grid.Column="6" 
                                Content="{StaticResource imageCheck64}" 
                                Command="{Binding DataContext.SendTestNotificationCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                ToolTip="Отправить тестовое уведомление всем пользователям" 
                                Padding="0" 
                                Height="24" 
                                Margin="1,0"></Button>
                    </Grid>
                </DataTemplate>
            </Expander.HeaderTemplate>
            <DataGrid ItemsSource="{Binding CurrentMessageLogFilteredNotifications, Mode=OneWay}"
                      AutoGenerateColumns="False" 
                      VerticalScrollBarVisibility="Visible"
                      HorizontalScrollBarVisibility="Auto"
                      ColumnWidth="*"
                      Height="200"
                      MinHeight="200"
                      CanUserResizeRows="True">
                <DataGrid.Resources>
                    <DataTemplate x:Key="IconColumnTemplate">
                        <Image Source="{Binding CriticalLevel, Converter={StaticResource criticalLevelToIconConverter}}" Height="15"></Image>
                    </DataTemplate>
                </DataGrid.Resources>
                <DataGrid.Columns>
                    <DataGridTemplateColumn Header="К." CellTemplate="{StaticResource IconColumnTemplate}" Width="auto" MaxWidth="30" IsReadOnly="True"></DataGridTemplateColumn>
                    <DataGridTextColumn Header="Время" Binding="{Binding DateTime,ConverterCulture=ru-RY}" Width="auto" MinWidth="120" IsReadOnly="True"></DataGridTextColumn>
                    <DataGridTextColumn Header="Отправитель" Binding="{Binding SenderDisplayName}" Width="auto" MinWidth="150" IsReadOnly="True"></DataGridTextColumn>
                    <DataGridTemplateColumn Header="Сообщение" Width="7*" MinWidth="900" IsReadOnly="True">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Text}" TextWrapping="Wrap" Height="auto" MaxHeight="50"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="Источник" Binding="{Binding Source}" Width="*" MinWidth="350" IsReadOnly="True"></DataGridTextColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Expander>
    </Grid>
</UserControl>

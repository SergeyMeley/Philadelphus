<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Philadelphus.Presentation.Avalonia.Views.Windows.LaunchWindow"
        Title="Philadelphus"
        Width="1000"
        Height="650"
        WindowStartupLocation="CenterScreen">
    <!-- Каркас. Контент LaunchWindow переносится из WPF инкрементально. -->
    <Grid>
        <TextBlock Text="LaunchWindow (Avalonia) — каркас"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Opacity="0.5" />
    </Grid>
</Window>

<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:beh="clr-namespace:Philadelphus.Presentation.Avalonia.Behaviors"
             x:Class="Philadelphus.Presentation.Avalonia.Views.Controls.RepositoryExplorer.RepositoryExplorerChildrenFlatTable">
    <Grid RowDefinitions="Auto,*,Auto">
        <!-- TODO этап D: <local:FormulaBar DataContext="{Binding FormulaBarVM}" /> -->
        <Border Grid.Row="0" Height="28" Background="#FFF7F7F7" BorderBrush="LightGray" BorderThickness="0,0,0,1" Margin="0,0,0,2">
            <TextBlock VerticalAlignment="Center" Margin="6,0" Opacity="0.5" Text="Строка формул — перенос на этапе D" />
        </Border>

        <!-- Колонки строятся behavior-ом из ChildCollectionTableColumns (ViewModel не зависит от DataGrid). -->
        <DataGrid x:Name="SelectedElementChildsDataGrid"
                  Grid.Row="1"
                  Margin="1"
                  MinHeight="50"
                  AutoGenerateColumns="False"
                  ItemsSource="{Binding ChildCollectionTableRows}"
                  beh:DataGridColumnsBehavior.ColumnsSource="{Binding ChildCollectionTableColumns}" />

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom">
            <TextBlock Text="{Binding #SelectedElementChildsDataGrid.SelectedIndex, Converter={StaticResource selectedIndexConverter}}" FontSize="10" />
            <TextBlock Text=" / " FontSize="10" />
            <TextBlock Text="{Binding ChildCollectionTableRows.Count}" FontSize="10" />
        </StackPanel>
    </Grid>
</UserControl>

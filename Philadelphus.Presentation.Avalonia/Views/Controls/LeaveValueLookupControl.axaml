<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:beh="clr-namespace:Philadelphus.Presentation.Avalonia.Behaviors"
             xmlns:localControls="clr-namespace:Philadelphus.Presentation.Avalonia.Controls"
             x:Class="Philadelphus.Presentation.Avalonia.Views.Controls.LeaveValueLookupControl">
    <Grid RowDefinitions="Auto,*"
          RowSpacing="8">
        <HeaderedContentControl Header="Найти / Создать">
            <Grid Margin="8"
                  RowDefinitions="Auto,Auto"
                  RowSpacing="8">
                <StackPanel Orientation="Horizontal"
                            Spacing="4"
                            HorizontalAlignment="Left">
                    <Button Width="25"
                            Height="25"
                            Padding="2,0"
                            Classes="logbtn"
                            Command="{Binding ValueLookup.CreateCommand}"
                            ToolTip.Tip="Создать лист по условиям поиска">
                        <localControls:ThemedSvg Icon="leave"
                                                 Width="15"
                                                 Height="15" />
                    </Button>
                    <Button Width="25"
                            Height="25"
                            Padding="2,0"
                            Classes="logbtn"
                            IsVisible="{Binding !ValueLookup.IsSystemValue}"
                            Command="{Binding ValueLookup.ClearSelectedAttributeCriterionCommand}"
                            ToolTip.Tip="Очистить значение выбранного атрибута">
                        <localControls:ThemedSvg Icon="broom"
                                                 Width="15"
                                                 Height="15" />
                    </Button>
                </StackPanel>

                <Grid Grid.Row="1"
                      ColumnDefinitions="180,*"
                      ColumnSpacing="8"
                      IsVisible="{Binding ValueLookup.IsSystemValue}">
                    <TextBlock VerticalAlignment="Center"
                               Text="Значение:" />
                    <TextBox Grid.Column="1"
                             Text="{Binding ValueLookup.SystemValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Watermark="Введите значение для поиска" />
                </Grid>

                <DataGrid Grid.Row="1"
                          IsVisible="{Binding !ValueLookup.IsSystemValue}"
                          ItemsSource="{Binding ValueLookup.AttributeCriteria}"
                          SelectedItem="{Binding ValueLookup.SelectedAttributeCriterion, Mode=TwoWay}"
                          AutoGenerateColumns="False"
                          HeadersVisibility="Column"
                          CanUserResizeColumns="True"
                          MinHeight="96"
                          MaxHeight="240">
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="Атрибут"
                                                Width="2*"
                                                MinWidth="140"
                                                IsReadOnly="True">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Margin="4,0"
                                               VerticalAlignment="Center"
                                               Text="{Binding Name}"
                                               TextTrimming="CharacterEllipsis"
                                               ToolTip.Tip="{Binding DeclaringUuid}" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="Значение для поиска"
                                                Width="3*"
                                                MinWidth="240"
                                                IsReadOnly="True">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Grid Margin="4,2">
                                        <ComboBox HorizontalAlignment="Stretch"
                                                  IsVisible="{Binding CanSelectValueFromList}"
                                                  ItemsSource="{Binding AvailableValues}"
                                                  SelectedItem="{Binding SelectedValue, Mode=TwoWay}"
                                                  PlaceholderText="Пустое значение">
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding DisplayName}" />
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>

                                        <ComboBox HorizontalAlignment="Stretch"
                                                  IsVisible="{Binding CanEnterValueManually}"
                                                  IsEditable="True"
                                                  IsTextSearchEnabled="False"
                                                  ItemsSource="{Binding AvailableValues}"
                                                  Text="{Binding ValueText, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                                  TextSearch.TextBinding="{Binding DisplayName}"
                                                  PlaceholderText="Пустое значение">
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding DisplayName}" />
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>

                                        <ItemsControl IsVisible="{Binding IsCollection}"
                                                      ItemsSource="{Binding AvailableValues}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel Orientation="Horizontal" />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <CheckBox Margin="0,0,12,2"
                                                              Content="{Binding DisplayName}"
                                                              IsChecked="{Binding IsSelected, Mode=TwoWay}" />
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Grid>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

            </Grid>
        </HeaderedContentControl>

        <HeaderedContentControl Grid.Row="1"
                                Header="Доступные значения">
            <Grid Margin="8"
                  RowDefinitions="Auto,*"
                  RowSpacing="8">
                <Grid ColumnDefinitions="*,Auto">
                    <StackPanel Orientation="Horizontal"
                                Spacing="16">
                        <CheckBox IsChecked="{Binding ShowOnlyMatches, Mode=TwoWay}"
                                  Content="Показывать только подходящие"
                                  ToolTip.Tip="При ошибке условий поиска отображаются все значения." />
                        <CheckBox IsVisible="{Binding ValueLookup.CanConfigureExactMatch}"
                                  IsChecked="{Binding ValueLookup.OnlyExactMatch, Mode=TwoWay}"
                                  Content="Только полное совпадение" />
                    </StackPanel>
                    <TextBlock Grid.Column="1"
                               VerticalAlignment="Center"
                               Text="{Binding SearchMatchCount, StringFormat='Совпадений: {0}'}" />
                </Grid>

                <DataGrid Grid.Row="1"
                          MinHeight="140"
                          AutoGenerateColumns="False"
                          ItemsSource="{Binding Rows}"
                          beh:DataGridColumnsBehavior.ColumnsSource="{Binding Columns}"
                          beh:DataGridSearchResultsBehavior.IsEnabled="True"
                          beh:DataGridSearchResultsBehavior.ResolvedRow="{Binding ResolvedSearchRow}">
                    <DataGrid.Styles>
                        <Style Selector="DataGridRow.search-match">
                            <Setter Property="Background" Value="#403CB371" />
                            <Setter Property="FontWeight" Value="SemiBold" />
                        </Style>
                    </DataGrid.Styles>
                </DataGrid>
            </Grid>
        </HeaderedContentControl>
    </Grid>
</UserControl>

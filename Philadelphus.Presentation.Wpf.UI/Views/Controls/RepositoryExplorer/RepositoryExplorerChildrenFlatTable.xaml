<UserControl x:Class="Philadelphus.Presentation.Wpf.UI.Views.Controls.RepositoryExplorer.RepositoryExplorerChildrenFlatTable"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Philadelphus.Presentation.Wpf.UI.Views.Controls.RepositoryExplorer"
             xmlns:behaviors="clr-namespace:Philadelphus.Presentation.Wpf.UI.Behaviors"
             mc:Ignorable="d"
             d:DesignHeight="450"
             d:DesignWidth="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="auto" />
        </Grid.RowDefinitions>
        <local:FormulaBar Grid.Row="0"
                          DataContext="{Binding FormulaBarVM}" />
        <!-- Колонки строятся behavior-ом из ChildCollectionTableColumns, чтобы ViewModel
             оставалась независимой от WPF DataGrid и code-behind. -->
        <DataGrid x:Name="SelectedElementChildsDataGrid"
                  Grid.Row="1"
                  Margin="1"
                  MinHeight="50"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  EnableRowVirtualization="True"
                  EnableColumnVirtualization="True"
                  HorizontalScrollBarVisibility="Auto"
                  VerticalScrollBarVisibility="Auto"
                  IsReadOnly="False"
                  SelectionUnit="Cell"
                  behaviors:DataGridLostKeyboardFocusCommandBehavior.Command="{Binding RebuildChildCollectionTableIfOrderStaleCommand}"
                  behaviors:DataGridFormulaCellSelectionBehavior.Command="{Binding FormulaBarVM.SelectChildFormulaCellCommand}"
                  behaviors:DataGridFormulaReferenceHighlightBehavior.IsActive="{Binding FormulaBarVM.IsFormulaReferenceSelectionActive}"
                  behaviors:DataGridFormulaReferenceHighlightBehavior.AttributeColumnsOnly="True"
                  behaviors:DataGridCellFocusRequestBehavior.FocusRequestId="{Binding FormulaBarVM.FormulaValueCellFocusRequestId, Mode=OneWay}"
                  behaviors:DataGridColumnsBehavior.ColumnsSource="{Binding ChildCollectionTableColumns}"
                  ItemsSource="{Binding ChildCollectionTableRows}" />
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom">
            <TextBlock Text="{Binding SelectedIndex, ElementName=SelectedElementChildsDataGrid, Converter={StaticResource selectedIndexConverter}}"
                       FontSize="10" />
            <TextBlock Text=" / " FontSize="10" />
            <TextBlock Text="{Binding Items.Count, ElementName=SelectedElementChildsDataGrid}"
                       FontSize="10" />
        </StackPanel>
    </Grid>
</UserControl>

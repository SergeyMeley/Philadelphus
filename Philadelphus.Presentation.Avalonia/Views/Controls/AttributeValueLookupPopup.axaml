<Popup xmlns="https://github.com/avaloniaui"
       xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
       xmlns:controls="clr-namespace:Philadelphus.Presentation.Avalonia.Views.Controls"
       x:Class="Philadelphus.Presentation.Avalonia.Views.Controls.AttributeValueLookupPopup"
       Placement="Bottom"
       VerticalOffset="2">
    <Border Width="1000"
            MaxHeight="760"
            Padding="10"
            Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
            BorderBrush="{DynamicResource SystemControlForegroundBaseMediumBrush}"
            BorderThickness="1"
            CornerRadius="4">
        <Grid RowDefinitions="Auto,*,Auto"
              RowSpacing="8">
            <StackPanel Orientation="Horizontal"
                        Spacing="4">
                <TextBlock FontWeight="SemiBold"
                           Text="Расширенный выбор значения:" />
                <TextBlock Text="{Binding Attribute.Name}" />
            </StackPanel>

            <controls:LeaveValueLookupControl Grid.Row="1" />

            <Button Grid.Row="2"
                    HorizontalAlignment="Right"
                    MinWidth="90"
                    Click="ClosePopup"
                    Content="Закрыть" />
        </Grid>
    </Border>
</Popup>

<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Philadelphus.Presentation.Avalonia.Views.Controls.LeaveValueLookupControl"
             IsVisible="{Binding IsSystemValue}">
    <Border Padding="8"
            BorderThickness="1"
            CornerRadius="4"
            BorderBrush="{DynamicResource ThemeBorderLowBrush}">
        <StackPanel Spacing="6">
            <TextBlock Text="Поиск значения"
                       FontWeight="SemiBold" />

            <Grid ColumnDefinitions="Auto,*,Auto"
                  ColumnSpacing="8">
                <TextBlock VerticalAlignment="Center"
                           Text="Значение:" />
                <TextBox Grid.Column="1"
                         Text="{Binding SystemValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         Watermark="Введите значение для поиска" />
                <Button Grid.Column="2"
                        Command="{Binding CreateCommand}"
                        Content="Создать" />
            </Grid>

            <Grid ColumnDefinitions="*,Auto"
                  ColumnSpacing="8">
                <TextBlock Text="{Binding StatusText}" />
                <TextBlock Grid.Column="1"
                           Text="{Binding MatchCount, StringFormat='Совпадений: {0}'}" />
            </Grid>
        </StackPanel>
    </Border>
</UserControl>

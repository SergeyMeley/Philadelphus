                <TabItem Classes="compact" Header="Родительский элемент" IsEnabled="False" />
                <TabItem Classes="compact" Header="Дерево" IsEnabled="False" />
                <TabItem Classes="compact" Header="Кустарник">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <local:MainEntityDetails />
                    </ScrollViewer>
                </TabItem>
                <TabItem Classes="compact" Header="Репозиторий">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <local:MainEntityModelDetails DataContext="{Binding Model.OwningRepository}" />

<fluent:RibbonWindow x:Class="Philadelphus.Presentation.Wpf.UI.Views.Windows.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Philadelphus.Presentation.Wpf.UI.Views.Windows"
        xmlns:fluent="urn:fluent-ribbon"
        xmlns:viewmodels="clr-namespace:Philadelphus.Presentation.Wpf.UI.ViewModels"
        xmlns:i="Microsoft.Xaml.Behaviors;assembly=System.Windows.Interactivity"
        xmlns:ctrls="clr-namespace:Philadelphus.Presentation.Wpf.UI.Views.Controls"
        xmlns:re="clr-namespace:Philadelphus.Presentation.Wpf.UI.Views.Controls.RepositoryExplorer"
        xmlns:ntf="clr-namespace:Philadelphus.Core.Domain.Services.Interfaces;assembly=Philadelphus.Core.Domain" 
        mc:Ignorable="d"
        Title="{Binding Title}"
        MinHeight="500" MinWidth="1000"
        WindowState="Maximized"
        Icon="{StaticResource imagePhiladelphusLogo}"
        Background="{DynamicResource BackgroundBrush}"
        Foreground="{DynamicResource ForegroundBrush}">
    <fluent:RibbonWindow.CommandBindings>
        <!--<CommandBinding Command="New" CanExecute="CommonCommandBinding_CanExecute" />
        <CommandBinding Command="Open" CanExecute="CommonCommandBinding_CanExecute" />
        <CommandBinding Command="Save" CanExecute="CommonCommandBinding_CanExecute" />-->
    </fluent:RibbonWindow.CommandBindings>
    <Grid>
        <Grid.Background>
            <SolidColorBrush Color="#FFF1F1F1"/>
        </Grid.Background>
        <Popup DataContext="{Binding PopupVM}" IsOpen="{Binding IsOpen}" Placement="Top" PlacementTarget="{Binding ElementName=popupTarget}" HorizontalAlignment="Right" HorizontalOffset="-5" VerticalOffset="-5" AllowsTransparency="True" PopupAnimation="Scroll">
            <StackPanel>
                <ListBox ItemsSource="{Binding NotificationList}">
                    <ListBox.ItemTemplate>
                        <ItemContainerTemplate>
                            <Border BorderThickness="3" CornerRadius="5" BorderBrush="SlateGray" Background="LightGray">
                                <StackPanel>
                                    <TextBlock Height="70" Width="300" Padding="10" Text="{Binding Text}"></TextBlock>
                                </StackPanel>
                            </Border>
                        </ItemContainerTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </StackPanel>
        </Popup>
        <DockPanel LastChildFill="True">
            <fluent:Ribbon DockPanel.Dock="Top" Background="Transparent"
               xmlns:fluent="urn:fluent-ribbon">

                <fluent:Ribbon.QuickAccessItems>
                </fluent:Ribbon.QuickAccessItems>

                <fluent:Ribbon.Menu>
                    <fluent:ApplicationMenu Visibility="Collapsed">

                        <!--<RibbonApplicationMenu.SmallImageSource>
                            <BitmapImage UriSource="C:\Users\MeleychukSV\Downloads\icons8-квадратный-корень-2-64.png" />
                        </RibbonApplicationMenu.SmallImageSource>-->


                        <fluent:MenuItem Header="Hello _Ribbon" />
                        <fluent:Button Content="Открыть локальный репозиторий"/>
                        <fluent:Button Content="Открыть удаленный репозиторий"/>
                        <fluent:Button Content="Создать пустой репозиторий"/>
                        <fluent:Button Content="Создать из шаблона"/>
                    </fluent:ApplicationMenu>
                </fluent:Ribbon.Menu>

                <fluent:RibbonTabItem Header="Главная">
                    <fluent:RibbonGroupBox Header="Общее">
                        <fluent:Button Content="Открыть стартовое окно"
                           Command="{Binding OpenLaunchWindowCommand}" />
                    </fluent:RibbonGroupBox>

                    <!--<RibbonGroup Header="Буфер обмена">
            <RibbonButton Label="Копировать" />
            <RibbonButton Label="Вырезать" />
            <RibbonButton Label="Вставить" />
            <RibbonButton Label="Дублировать" />
            <RibbonButton Label="Переместить" />
        </RibbonGroup>-->
                </fluent:RibbonTabItem>

                <fluent:RibbonTabItem Header="Репозиторий">

                    <fluent:RibbonGroupBox Header="Текущий репозиторий">

                        <!--<RibbonComboBox ... />-->

                        <!--<ComboBox ... />-->

                        <TextBlock Text="{Binding RepositoryExplorerVM.PhiladelphusRepositoryVM.Name}"/>

                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Состояние: "/>
                            <TextBlock Text="{Binding RepositoryExplorerVM.PhiladelphusRepositoryVM.State}"/>
                        </StackPanel>

                        <fluent:Button Content="Открыть стартовое окно"
                           Command="{Binding ApplicationCommandsVM.OpenLaunchWindowCommand}" />
                    </fluent:RibbonGroupBox>

                    <fluent:RibbonGroupBox Header="Информация">

                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Количество корней: "/>
                            <TextBlock Text="{Binding RepositoryExplorerVM.PhiladelphusRepositoryVM.ChildsCount}"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Текущий участник репозитория: "/>
                            <TextBlock Text="{Binding RepositoryExplorerVM.SelectedRepositoryMember.Name}"/>
                        </StackPanel>

                        <fluent:Button Content="Подробнее"
                           Command="{Binding OpenRepositoryMemberDetailsWindowCommand}" />
                    </fluent:RibbonGroupBox>

                    <!--<RibbonGroup Header="Иерархия репозитория">...</RibbonGroup>-->
                    <!--<RibbonGroup Header="Вхождения атрибутов">...</RibbonGroup>-->
                    <!--<RibbonGroup Header="Атрибуты">...</RibbonGroup>-->
                    <!--<RibbonGroup Header="Пресеты">...</RibbonGroup>-->

                </fluent:RibbonTabItem>

                <fluent:RibbonTabItem Header="Данные">

                    <fluent:RibbonGroupBox Header="Импорт">
                        <fluent:Button Content="Импорт дерева из .phjson"
                           Command="{Binding RepositoryExplorerVM.ImportFromPhjsonCommand}" />
                    </fluent:RibbonGroupBox>

                    <fluent:RibbonGroupBox Header="Экспорт">
                        <fluent:Button Content="Экспорт дерева в .phjson"
                           Command="{Binding RepositoryExplorerVM.ExportToPhjsonCommand}" />
                    </fluent:RibbonGroupBox>

                    <fluent:RibbonGroupBox Header="Конвертация">
                        <fluent:Button Content="Конвертировать .xlsx в .phjson"
                           Command="{Binding RepositoryExplorerVM.ConvertXlsxToPhjsonCommand}" />
                    </fluent:RibbonGroupBox>

                </fluent:RibbonTabItem>

                <fluent:RibbonTabItem Header="Расширения"
                          DataContext="{Binding ExtensionsControlVM}">

                    <fluent:RibbonGroupBox Header="Текущее расширение">

                        <ComboBox ItemsSource="{Binding Extensions}"
                      DisplayMemberPath="Name"
                      SelectedItem="{Binding SelectedExtension}"
                      IsEditable="True"
                      IsReadOnly="True"
                      Width="200"/>

                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Состояние: "/>
                            <TextBlock Text="{Binding SelectedExtension.State}"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal">
                            <fluent:Button Content="Запустить"
                               Command="{Binding StartExtensionCommand}"/>
                            <fluent:Button Content="Остановить"
                               Command="{Binding StopExtensionCommand}"/>
                        </StackPanel>

                        <fluent:Button Content="Выполнить"
                           Command="{Binding ExecuteExtensionCommand}"/>

                        <fluent:ToggleButton Content="Окно"
                                 Command="{Binding OpenMainWindowCommand}"
                                 IsChecked="{Binding SelectedExtension.Window.IsVisible, Mode=OneWay}"/>
                    </fluent:RibbonGroupBox>

                    <fluent:RibbonGroupBox Header="Виджеты расширений">
                        <ContentControl Content="{Binding SelectedExtension.RibbonWidget}"/>
                    </fluent:RibbonGroupBox>

                </fluent:RibbonTabItem>

            </fluent:Ribbon>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="4*"></RowDefinition>
                    <RowDefinition Height="auto"></RowDefinition>
                    <RowDefinition Height="auto" MaxHeight="350"></RowDefinition>
                    <RowDefinition Height="auto"></RowDefinition>
                    <RowDefinition Height="0"></RowDefinition>
                </Grid.RowDefinitions>
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="auto" MaxWidth="300"></ColumnDefinition>
                        <ColumnDefinition Width="auto"></ColumnDefinition>
                        <ColumnDefinition Width="5*"></ColumnDefinition>
                    </Grid.ColumnDefinitions>
                    <!--<Expander Grid.Row="2" Grid.Column="0" ExpandDirection="Left" Margin="1">
                            <Expander.Header>
                                <TextBlock Text="Навигационная панель">
                                    <TextBlock.LayoutTransform>
                                        <RotateTransform Angle="-90"/>
                                    </TextBlock.LayoutTransform>
                                </TextBlock>
                            </Expander.Header>
                            <Grid Grid.Row="0" Grid.Column="0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"></RowDefinition>
                                    <RowDefinition Height="auto"></RowDefinition>
                                    <RowDefinition Height="*"></RowDefinition>
                                </Grid.RowDefinitions>
                                <GroupBox Grid.Row="0" Grid.Column="0" Header="Сервисы" Margin="1" Background="White">
                                    <ListBox>
                                        <ListBoxItem Content="Дерево данных"></ListBoxItem>
                                        <ListBoxItem Content="Атрибуты"></ListBoxItem>
                                        <ListBoxItem Content="Отчеты"></ListBoxItem>
                                        <ListBoxItem Content="Настраиваемый отчет"></ListBoxItem>
                                        <ListBoxItem Content="Импорт / экспорт репозитория"></ListBoxItem>
                                        <ListBoxItem Content="Расширения, надстройки"></ListBoxItem>
                                        <ListBoxItem Content="Общие настройки"></ListBoxItem>
                                        <ListBoxItem Content="Настройки репозитория"></ListBoxItem>
                                        <ListBoxItem Content="Администрирование"></ListBoxItem>
                                    </ListBox>
                                </GroupBox>
                                <GridSplitter Grid.Row="1" Grid.Column="0" ShowsPreview="False" Height="3" HorizontalAlignment="Stretch" VerticalAlignment="Center"></GridSplitter>
                                <GroupBox Grid.Row="2" Grid.Column="0" Header="Надстройки" Margin="1" Background="White">
                                    <ListBox>
                                        <ListBoxItem Content="Git"></ListBoxItem>
                                        <ListBoxItem Content="Расчет трубопроводных элементов"></ListBoxItem>
                                        <ListBoxItem Content="Определение критической точки"></ListBoxItem>
                                        <ListBoxItem Content="Номинальные давления"></ListBoxItem>
                                        <ListBoxItem Content="Допускаемые напряжения"></ListBoxItem>
                                    </ListBox>
                                </GroupBox>
                            </Grid>
                        </Expander>
                        <GridSplitter Grid.Row="0" Grid.Column="1" ShowsPreview="False" Width="3" HorizontalAlignment="Center" VerticalAlignment="Stretch"></GridSplitter>-->
                    <GroupBox Grid.Row="0" Grid.Column="2" Header="Рабочая область" Margin="1" Background="White">
                        <TabControl Margin="1">
                            <TabItem Header="Репозиторий">
                                <re:RepositoryExplorer DataContext="{Binding RepositoryExplorerVM}"></re:RepositoryExplorer>
                            </TabItem>
                            <!--<TabItem Header="Отчеты">
                                    <ctrls:ReportProcessor></ctrls:ReportProcessor>
                                </TabItem>
                                <TabItem Header="Настраиваемый отчет">
                                    <ctrls:CustomizableReport></ctrls:CustomizableReport>
                                </TabItem>
                                <TabItem Header="Импорт / экспорт">
                                    <ctrls:DataExchange></ctrls:DataExchange>
                                </TabItem>-->
                            <TabItem Header="Настройки">
                                <ctrls:ApplicationSettings DataContext="{Binding ApplicationSettingsControlVM}"></ctrls:ApplicationSettings>
                            </TabItem>
                        </TabControl>
                    </GroupBox>
                </Grid>

                <ctrls:MessageLog Grid.Row="1" DataContext="{Binding MainWindowNotificationsVM.MessageLogControlVM}"></ctrls:MessageLog>
                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition></ColumnDefinition>
                        <ColumnDefinition Width="320"></ColumnDefinition>
                    </Grid.ColumnDefinitions>
                    <StackPanel x:Name="popupTarget" Grid.Column="1"></StackPanel>
                </Grid>
                <StatusBar Grid.Row="3">
                    <StatusBar.ItemsPanel>
                        <ItemsPanelTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="auto"/>
                                </Grid.ColumnDefinitions>
                            </Grid>
                        </ItemsPanelTemplate>
                    </StatusBar.ItemsPanel>

                    <StatusBarItem Grid.Column="0">
                        <TextBlock Text="{Binding UserName}"/>
                    </StatusBarItem>

                    <StatusBarItem Grid.Column="2">
                        <TextBlock Text="{Binding AssemblyVersion}" HorizontalAlignment="Right"/>
                    </StatusBarItem>
                    <!--<TextBlock Text="Приложение запущено"></TextBlock>-->
                </StatusBar>
                <ProgressBar Grid.Row="4" Minimum="0" Maximum="100" Value="{Binding CurrentProgress}" Height="3"></ProgressBar>
            </Grid>
        </DockPanel>
    </Grid>
</fluent:RibbonWindow>

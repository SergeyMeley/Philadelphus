<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Philadelphus.Presentation.Avalonia.Views.Controls.RepositoryExplorer"
             xmlns:localControls="clr-namespace:Philadelphus.Presentation.Avalonia.Controls"
             x:Class="Philadelphus.Presentation.Avalonia.Views.Controls.RepositoryExplorer.Attributes">
    <Grid RowDefinitions="Auto,Auto,*,Auto">
        <!-- Тулбар атрибутов -->
        <StackPanel Grid.Row="0" Orientation="Horizontal">
            <StackPanel Orientation="Horizontal" IsEnabled="{Binding !IsReadOnly}">
                <Button Command="{Binding CreateAttributeCommand}" ToolTip.Tip="Добавить атрибут" Margin="1" Height="25" Width="25" Padding="2" Background="Transparent">
                    <localControls:ThemedSvg Icon="add" />
                </Button>
                <Button Command="{Binding SoftDeleteRepositoryMemberAttributeCommand}" ToolTip.Tip="Удалить атрибут" Margin="1" Height="25" Width="25" Padding="2" Background="Transparent">
                    <localControls:ThemedSvg Icon="remove" />
                </Button>
                <Button Command="{Binding OpenModifyAttributesListWindowCommand}" ToolTip.Tip="Открыть настройки списка" Margin="1" Height="25" Width="25" Padding="2" Background="Transparent">
                    <localControls:ThemedSvg Icon="list" />
                </Button>
                <Button Command="{Binding CreatePolymorphicParentCommand}"
                        CommandParameter="{Binding SelectedRepositoryMember.SelectedAttributeVM.LeavePolymorphism}"
                        IsEnabled="{Binding SelectedRepositoryMember.SelectedAttributeVM.LeavePolymorphism.CanCreateParent}"
                        ToolTip.Tip="Создать отсутствующего полиморфного родителя"
                        Margin="1" Height="25" Width="25" Padding="2" Background="Transparent">
                    <localControls:ThemedSvg Icon="leave" />
                </Button>
            </StackPanel>
            <Button Command="{Binding NavigationVM.NavigateToAttributeDataTypeCommand}"
                    CommandParameter="{Binding FormulaBarVM.SelectedFormulaAttribute}"
                    ToolTip.Tip="Перейти к узлу типа данных"
                    Margin="1" Height="25" Width="25" Padding="2" Background="Transparent">
                <localControls:ThemedSvg Icon="navigate-node" />
            </Button>
            <Button Command="{Binding NavigationVM.NavigateToAttributeValueCommand}"
                    CommandParameter="{Binding FormulaBarVM.SelectedFormulaAttribute}"
                    ToolTip.Tip="Перейти к листу значения"
                    Margin="1" Height="25" Width="25" Padding="2" Background="Transparent">
                <localControls:ThemedSvg Icon="navigate-leave" />
            </Button>
        </StackPanel>

        <local:FormulaBar Grid.Row="1" DataContext="{Binding FormulaBarVM}" />

        <DataGrid Name="SelectedElementAttributesDataGrid"
                  Grid.Row="2"
                  ItemsSource="{Binding SelectedRepositoryMember.AttributesVMs}"
                  SelectedItem="{Binding FormulaBarVM.SelectedFormulaAttribute, Mode=TwoWay}"
                  SelectionMode="Single"
                  AutoGenerateColumns="False">
            <DataGrid.Styles>
                <!-- Полупрозрачный оттенок одинаково читается в светлой и тёмной темах.
                     Класс назначается только метаданным; ячейки значений остаются без заливки. -->
                <Style Selector="DataGridCell.runtimeMetadata">
                    <Setter Property="Background"
                            Value="{Binding IsRuntime, Converter={StaticResource boolToBrushConverter}, ConverterParameter=#180078D4|}" />
                </Style>
            </DataGrid.Styles>
            <DataGrid.Columns>
                <!-- Состояние -->
                <DataGridTemplateColumn Width="7" MinWidth="0" CellStyleClasses="statusStripe runtimeMetadata">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <localControls:StateVisibilityStripe ParentOwnerState="{Binding ParentOwnerAggregateState}"
                                                                 State="{Binding State}"
                                                                 ChildContentState="{Binding ChildContentAggregateState}"
                                                                 StateVisibilityToolTip="{Binding StateVisibilityToolTip}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTextColumn Header="Uuid" Binding="{Binding Uuid, Mode=OneWay}" IsReadOnly="True" CellStyleClasses="runtimeMetadata" />
                <DataGridTextColumn Header="Наименование" Binding="{Binding Name}" CellStyleClasses="runtimeMetadata" />

                <!-- Тип данных -->
                <DataGridTemplateColumn Header="Тип данных" CellStyleClasses="runtimeMetadata">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <ComboBox HorizontalAlignment="Stretch"
                                      IsEnabled="{Binding !IsRuntime}"
                                      ItemsSource="{Binding ValueTypesList}"
                                      SelectedItem="{Binding SelectedValueType, Mode=TwoWay}"
                                      PlaceholderText="{Binding ValueTypeReferenceErrorCode}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate><TextBlock Text="{Binding Name}" /></DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridCheckBoxColumn Header="Массив" Binding="{Binding IsCollectionValue}" CellStyleClasses="runtimeMetadata" />

                <!-- Значение: подсветка «переопределено» (Moccasin, статусный цвет; текст чёрный для
                     читаемости в обеих темах) + редактируемый ввод через AutoCompleteBox
                     (Avalonia ComboBox не editable): ввод формулы — Text=FormulaValueText, выбор из ValuesList. -->
                <DataGridTemplateColumn Header="Значение">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                                    Background="{Binding IsValueOverridden, Converter={StaticResource boolToBrushConverter}, ConverterParameter=Moccasin|}"
                                    ToolTip.Tip="{Binding ValueOverrideToolTip}">
                                <TextBlock Text="{Binding DisplayedValueText, Mode=OneWay}" VerticalAlignment="Center" Margin="2,0"
                                           Foreground="{Binding IsValueOverridden, Converter={StaticResource boolToBrushConverter}, ConverterParameter=Black|}" />
                            </Border>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                    <DataGridTemplateColumn.CellEditingTemplate>
                        <DataTemplate>
                            <!-- Штатный редактируемый ComboBox (Avalonia 11.3: IsEditable + Text).
                                 SelectedItem НЕ привязываем: при вводе текста, не совпадающего с элементом,
                                 ComboBox сбрасывает SelectedItem в null и обнуляет значение. Вместо этого всё
                                 идёт через Text=FormulaValueText: выбор из списка пишет в текст «[uuid]»
                                 (TextSearch.TextBinding), а сеттер FormulaValueText сам присваивает значение
                                 по ссылке (TryGetLeafUuidReference). Ввод формулы/значения — тоже через Text. -->
                            <ComboBox HorizontalAlignment="Stretch"
                                      IsEditable="True"
                                      IsTextSearchEnabled="False"
                                      ItemsSource="{Binding ValuesList}"
                                      Text="{Binding FormulaValueText, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                      TextSearch.TextBinding="{Binding Uuid, StringFormat='[{0}]'}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate><TextBlock Text="{Binding Name}" /></DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellEditingTemplate>
                </DataGridTemplateColumn>

                <!-- Присвоенные значения: подсветка «переопределено» коллекции. -->
                <DataGridTemplateColumn Header="Присвоенные значения" IsReadOnly="True">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                                    Background="{Binding AreValuesOverridden, Converter={StaticResource boolToBrushConverter}, ConverterParameter=Moccasin|}"
                                    ToolTip.Tip="{Binding ValuesOverrideToolTip}">
                                <TextBlock Text="{Binding AssignedValuesString, Mode=OneWay}" VerticalAlignment="Center" Margin="2,0"
                                           Foreground="{Binding AreValuesOverridden, Converter={StaticResource boolToBrushConverter}, ConverterParameter=Black|}" />
                            </Border>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Область видимости -->
                <DataGridTemplateColumn Header="Область видимости" CellStyleClasses="runtimeMetadata">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <!-- Выбор по ССЫЛКЕ (SelectedItem→SelectedVisibilityScope), НЕ по значению.
                                 SelectedValue+SelectedValueBinding в Avalonia теряет выбор при рециклинге
                                 ячеек DataGrid (значение «слетало» при добавлении/прокрутке) — см. тех-долг E. -->
                            <ComboBox HorizontalAlignment="Stretch"
                                      IsEnabled="{Binding !IsRuntime}"
                                      ItemsSource="{Binding VisibilityScopesList}"
                                      SelectedItem="{Binding SelectedVisibilityScope, Mode=TwoWay}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate><TextBlock Text="{Binding DisplayName}" /></DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Переопределение -->
                <DataGridTemplateColumn Header="Переопределение" CellStyleClasses="runtimeMetadata">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <!-- Выбор по ССЫЛКЕ (см. колонку «Область видимости» и тех-долг E). -->
                            <ComboBox HorizontalAlignment="Stretch"
                                      IsEnabled="{Binding !IsRuntime}"
                                      ItemsSource="{Binding OverrideTypesList}"
                                      SelectedItem="{Binding SelectedOverrideType, Mode=TwoWay}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate><TextBlock Text="{Binding DisplayName}" /></DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTextColumn Header="Глубина наследования" Binding="{Binding InheritanceDepth}" IsReadOnly="True" CellStyleClasses="runtimeMetadata" />
                <DataGridTextColumn Header="Владелец" Binding="{Binding DeclaringOwner.Name}" IsReadOnly="True" CellStyleClasses="runtimeMetadata" />
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom">
            <TextBlock Text="{Binding #SelectedElementAttributesDataGrid.SelectedIndex, Converter={StaticResource selectedIndexConverter}}" FontSize="10" />
            <TextBlock Text=" / " FontSize="10" />
            <TextBlock Text="{Binding SelectedRepositoryMember.AttributesVMs.Count}" FontSize="10" />
        </StackPanel>
    </Grid>
</UserControl>

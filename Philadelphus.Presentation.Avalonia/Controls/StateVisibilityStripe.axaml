<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:Philadelphus.Presentation.Avalonia.Controls"
             x:Class="Philadelphus.Presentation.Avalonia.Controls.StateVisibilityStripe"
             ToolTip.Tip="{Binding StateVisibilityToolTip, RelativeSource={RelativeSource Self}}">
    <Grid RowDefinitions="*,*,*"
          RowSpacing="1"
          Background="{DynamicResource SystemRegionBrush}">
        <Rectangle Grid.Row="0"
                   Fill="{Binding ParentOwnerState, RelativeSource={RelativeSource AncestorType=controls:StateVisibilityStripe}, Converter={StaticResource stateToColorConverter}}" />
        <Rectangle Grid.Row="1"
                   Fill="{Binding State, RelativeSource={RelativeSource AncestorType=controls:StateVisibilityStripe}, Converter={StaticResource stateToColorConverter}}" />
        <Rectangle Grid.Row="2"
                   Fill="{Binding ChildContentState, RelativeSource={RelativeSource AncestorType=controls:StateVisibilityStripe}, Converter={StaticResource stateToColorConverter}}" />
    </Grid>
</UserControl>

<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Button x:Key="buttonBack" Content="{StaticResource imageBack}" Margin="1" MinHeight="20" MinWidth="20" />
    <Button x:Key="buttonCopy" Content="{StaticResource imageCopy}" Margin="1" MinHeight="20" MinWidth="20" />
    <Button x:Key="buttonCut" Content="{StaticResource imageCut}" Margin="1" MinHeight="20" MinWidth="20" />
    <Button x:Key="buttonDuplicate" Content="{StaticResource imageDuplicate}" Margin="1" MinHeight="20" MinWidth="20" />
    <Button x:Key="buttonForward" Content="{StaticResource imageForward}" Margin="1" MinHeight="20" MinWidth="20" />
    <Button x:Key="buttonPaste" Content="{StaticResource imagePaste}" Margin="1" MinHeight="20" MinWidth="20" />
    <Button x:Key="buttonReturn" Content="{StaticResource imageReturn}" Margin="1" MinHeight="20" MinWidth="20" />
    <Button x:Key="buttonUp" Content="{StaticResource imageUp}" Margin="1" MinHeight="20" MinWidth="20" />
</ResourceDictionary>
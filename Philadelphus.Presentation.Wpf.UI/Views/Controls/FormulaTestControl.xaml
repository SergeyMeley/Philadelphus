<UserControl x:Class="Philadelphus.Presentation.Wpf.UI.Views.Controls.FormulaTestControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:behaviors="clr-namespace:Philadelphus.Presentation.Wpf.UI.Behaviors"
             mc:Ignorable="d"
             d:DesignHeight="450"
             d:DesignWidth="900">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0"
                   Grid.Column="0"
                   Margin="0,0,8,8"
                   VerticalAlignment="Center"
                   Text="Формула"/>
        <TextBox x:Name="FormulaTextBox"
                 Grid.Row="0"
                 Grid.Column="1"
                 Margin="0,0,8,8"
                 MinHeight="28"
                 VerticalContentAlignment="Center"
                 behaviors:FormulaSuggestionTextBoxBehavior.IsEnabled="True"
                 behaviors:FormulaSuggestionTextBoxBehavior.SuggestionsListBox="{Binding ElementName=FormulaSuggestionsListBox}"
                 Text="{Binding FormulaText, UpdateSourceTrigger=PropertyChanged}"/>
        <Popup Grid.Row="0"
               Grid.Column="1"
               AllowsTransparency="True"
               IsOpen="{Binding IsFormulaSuggestionsOpen}"
               Placement="Bottom"
               PlacementTarget="{Binding ElementName=FormulaTextBox}"
               PopupAnimation="Fade"
               StaysOpen="False">
            <Border MinWidth="{Binding ActualWidth, ElementName=FormulaTextBox}"
                    MaxWidth="520"
                    MaxHeight="260"
                    Background="White"
                    BorderBrush="#8A8A8A"
                    BorderThickness="1"
                    Padding="2">
                <ListBox x:Name="FormulaSuggestionsListBox"
                         ItemsSource="{Binding FormulaSuggestions}"
                         SelectedItem="{Binding SelectedFormulaSuggestion, Mode=TwoWay}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="4,3">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Row="0"
                                           Grid.Column="0"
                                           FontWeight="SemiBold"
                                           Text="{Binding DisplayName}"/>
                                <TextBlock Grid.Row="0"
                                           Grid.Column="1"
                                           Margin="12,0,0,0"
                                           Foreground="Gray"
                                           Text="{Binding Category}"/>
                                <TextBlock Grid.Row="1"
                                           Grid.Column="0"
                                           Grid.ColumnSpan="2"
                                           Foreground="DimGray"
                                           Text="{Binding Signature}"
                                           TextTrimming="CharacterEllipsis"/>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>
        </Popup>
        <Button Grid.Row="0"
                Grid.Column="2"
                Margin="0,0,0,8"
                MinWidth="120"
                Padding="12,4"
                Command="{Binding EvaluateFormulaCommand}"
                Content="Вычислить"/>
        <Border Grid.Row="1"
                Grid.Column="1"
                Grid.ColumnSpan="2"
                Margin="0,0,0,8"
                Padding="6,4"
                Background="#F7F7F7"
                BorderBrush="#D6D6D6"
                BorderThickness="1">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsFormulaHighlightOpen}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <ItemsControl ItemsSource="{Binding FormulaHighlightSegments}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <TextBlock FontFamily="Consolas"
                                   FontSize="13"
                                   Text="{Binding Text}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#2B2B2B"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="FontWeight" Value="Normal"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Kind}" Value="Function">
                                            <Setter Property="Foreground" Value="#005A9E"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Kind}" Value="Identifier">
                                            <Setter Property="Foreground" Value="#6A4C00"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Kind}" Value="Number">
                                            <Setter Property="Foreground" Value="#098658"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Kind}" Value="String">
                                            <Setter Property="Foreground" Value="#A31515"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Kind}" Value="TreeLeaveReference">
                                            <Setter Property="Foreground" Value="#795E26"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Kind}" Value="Parenthesis">
                                            <Setter Property="Foreground" Value="#5C2D91"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Kind}" Value="Punctuation">
                                            <Setter Property="Foreground" Value="#666666"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Kind}" Value="Operator">
                                            <Setter Property="Foreground" Value="#AF00DB"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Kind}" Value="Error">
                                            <Setter Property="Foreground" Value="#B00020"/>
                                            <Setter Property="Background" Value="#FFE5E5"/>
                                            <Setter Property="TextDecorations" Value="Underline"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsMatchingParenthesis}" Value="True">
                                            <Setter Property="Background" Value="#D7ECFF"/>
                                            <Setter Property="FontWeight" Value="Bold"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Border>
        <Border Grid.Row="2"
                Grid.Column="1"
                Grid.ColumnSpan="2"
                Margin="0,0,0,8"
                Padding="8,5"
                Background="#FFF8E7"
                BorderBrush="#D8B75A"
                BorderThickness="1">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsFormulaSignatureHelpOpen}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <StackPanel>
                <TextBlock FontWeight="SemiBold"
                           Text="{Binding FormulaSignatureText}"
                           TextTrimming="CharacterEllipsis"/>
                <TextBlock Margin="0,2,0,0"
                           Foreground="DimGray"
                           Text="{Binding FormulaActiveArgumentText}"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <TextBlock Grid.Row="3"
                   Grid.Column="0"
                   Margin="0,0,8,8"
                   VerticalAlignment="Center"
                   Text="Результат"/>
        <TextBox Grid.Row="3"
                 Grid.Column="1"
                 Grid.ColumnSpan="2"
                 Margin="0,0,0,8"
                 MinHeight="28"
                 IsReadOnly="True"
                 VerticalContentAlignment="Center"
                 Text="{Binding ResultText, Mode=OneWay}"/>

        <TextBlock Grid.Row="4"
                   Grid.Column="0"
                   Margin="0,0,8,8"
                   VerticalAlignment="Center"
                   Text="Тип"/>
        <TextBox Grid.Row="4"
                 Grid.Column="1"
                 Grid.ColumnSpan="2"
                 Margin="0,0,0,8"
                 MinHeight="28"
                 IsReadOnly="True"
                 VerticalContentAlignment="Center"
                 Text="{Binding ResultTypeText, Mode=OneWay}"/>

        <TextBlock Grid.Row="5"
                   Grid.Column="0"
                   Margin="0,0,8,0"
                   VerticalAlignment="Top"
                   Text="Ошибка"/>
        <TextBox Grid.Row="5"
                 Grid.Column="1"
                 Grid.ColumnSpan="2"
                 MinHeight="80"
                 AcceptsReturn="True"
                 IsReadOnly="True"
                 TextWrapping="Wrap"
                 VerticalScrollBarVisibility="Auto"
                 Text="{Binding ErrorText, Mode=OneWay}"/>
    </Grid>
</UserControl>

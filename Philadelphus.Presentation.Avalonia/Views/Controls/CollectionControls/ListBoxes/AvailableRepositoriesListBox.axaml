<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Philadelphus.Presentation.Avalonia.Views.Controls.CollectionControls.ListBoxes.AvailableRepositoriesListBox">
    <Grid>
        <ListBox Margin="1" BorderBrush="LightGray" BorderThickness="1"
                 ItemsSource="{Binding $parent[UserControl].RepositoriesItemsSource}"
                 SelectedItem="{Binding $parent[UserControl].RepositoriesSelectedItem, Mode=TwoWay}">
            <ListBox.Styles>
                <Style Selector="ListBoxItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                </Style>
            </ListBox.Styles>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition />
                            <RowDefinition />
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" MinWidth="300" />
                                <ColumnDefinition Width="*" MinWidth="300" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition />
                                <RowDefinition />
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Column="0" Grid.Row="0" Height="20" VerticalAlignment="Center" Margin="1">
                                <Run Text="Наименование: '" FontWeight="Light" /><Run Text="{Binding Name, Mode=OneWay}" /><Run Text="'. " />
                            </TextBlock>
                            <TextBlock Grid.Column="1" Grid.Row="0" Height="20" VerticalAlignment="Center" Margin="1">
                                <Run Text="Описание: '" FontWeight="Light" /><Run Text="{Binding Description, Mode=OneWay}" /><Run Text="'. " />
                            </TextBlock>
                            <TextBlock Grid.Column="2" Grid.Row="0" Height="20" VerticalAlignment="Center" Margin="1">
                                <Run Text="UUID: '" FontWeight="Light" /><Run Text="{Binding Uuid, Mode=OneWay}" /><Run Text="'. " />
                            </TextBlock>
                            <TextBlock Grid.Column="0" Grid.Row="1" Height="20" VerticalAlignment="Center" Margin="1">
                                <Run Text="Хранилище: '" FontWeight="Light" /><Run Text="{Binding OwnDataStorage.Name, Mode=OneWay}" /><Run Text="'. " />
                            </TextBlock>
                            <TextBlock Grid.Column="1" Grid.Row="1" Height="20" VerticalAlignment="Center" Margin="1">
                                <Run Text="Количество корней: '" FontWeight="Light" /><Run Text="{Binding ChildsCount, Mode=OneWay}" /><Run Text="'. " />
                            </TextBlock>
                        </Grid>
                        <Rectangle Grid.Row="1" HorizontalAlignment="Stretch" VerticalAlignment="Center" Fill="Gray" Height="1" />
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</UserControl>

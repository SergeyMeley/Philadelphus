<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Philadelphus.Presentation.Avalonia.Views.Windows.AttributeValuesCollectionWindow"
        Title="Список значений атрибута"
        Width="800"
        Height="600"
        WindowStartupLocation="CenterOwner">
    <!-- Каркас. Контент переносится из WPF инкрементально. -->
    <Grid>
        <TextBlock Text="AttributeValuesCollectionWindow (Avalonia) — каркас"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Opacity="0.5" />
    </Grid>
</Window>

<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ribbon="clr-namespace:Ribbon.Avalonia;assembly=Ribbon.Avalonia"
        xmlns:ctrls="clr-namespace:Philadelphus.Presentation.Avalonia.Views.Controls"
        xmlns:re="clr-namespace:Philadelphus.Presentation.Avalonia.Views.Controls.RepositoryExplorer"
        x:Class="Philadelphus.Presentation.Avalonia.Views.Windows.MainWindow"
        Title="{Binding Title}"
        MinHeight="500" MinWidth="1000"
        WindowState="Maximized"
        Icon="/Assets/Icons/philadelphus_logo_64.png">

    <!--
      WPF Window.CommandBindings (New/Open/Save) были закомментированы — перенос как комментарий:
      <CommandBinding Command="New" .../> <CommandBinding Command="Open" .../> <CommandBinding Command="Save" .../>
    -->

    <Window.Resources>
        <!-- Иконки для RibbonButton: свойство Icon/LargeIcon имеет тип IControlTemplate,
             поэтому растровую иконку оборачиваем в ControlTemplate с Image внутри. -->
        <ControlTemplate x:Key="IcoRoot"><Image Source="/Assets/Icons/root_64_1.png" /></ControlTemplate>
        <ControlTemplate x:Key="IcoNode"><Image Source="/Assets/Icons/node_64_3.png" /></ControlTemplate>
        <ControlTemplate x:Key="IcoLeave"><Image Source="/Assets/Icons/leave_64_3.png" /></ControlTemplate>
        <ControlTemplate x:Key="IcoDelete"><Image Source="/Assets/Icons/without_a_license/Flaticon_icon_delete.png" /></ControlTemplate>
        <ControlTemplate x:Key="IcoAdd"><Image Source="/Assets/Icons/without_a_license/Flaticon_icon_add.png" /></ControlTemplate>
        <ControlTemplate x:Key="IcoRemove"><Image Source="/Assets/Icons/without_a_license/Flaticon_icon_remove.png" /></ControlTemplate>
        <ControlTemplate x:Key="IcoDetails"><Image Source="/Assets/Icons/info_64_3.png" /></ControlTemplate>
    </Window.Resources>

    <Grid>
        <!-- Popup уведомлений (PopupVM). -->
        <Popup IsOpen="{Binding PopupVM.IsOpen}"
               PlacementTarget="{Binding #popupTarget}"
               Placement="Top"
               HorizontalOffset="-5"
               VerticalOffset="-5">
            <ListBox ItemsSource="{Binding PopupVM.NotificationList}">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border BorderThickness="3" CornerRadius="5"
                                BorderBrush="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                Background="{DynamicResource SystemControlBackgroundAltHighBrush}">
                            <TextBlock Width="300" Padding="10" TextWrapping="Wrap" Text="{Binding Text}" />
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Popup>

        <DockPanel>
            <!-- ===== Лента (Ribbon.Avalonia) =====
                 Вкладки обязательно лежат в свойстве Ribbon.Tabs (иначе полоса вкладок пустая). -->
            <ribbon:Ribbon DockPanel.Dock="Top" Orientation="Horizontal"
                           HelpButtonCommand="{Binding OpenAboutWindowCommand}">
                <ribbon:Ribbon.Tabs>
                    <ribbon:RibbonTab Header="Главная">
                        <ribbon:RibbonTab.Groups>
                            <ribbon:RibbonGroupBox Header="Общее">
                                <ribbon:RibbonButton Content="Стартовое окно" Command="{Binding OpenLaunchWindowCommand}" Size="Medium" MinSize="Medium" MaxSize="Medium" />
                            </ribbon:RibbonGroupBox>
                            <!--
                            <ribbon:RibbonGroupBox Header="Буфер обмена">
                                <ribbon:RibbonButton Content="Копировать" /><ribbon:RibbonButton Content="Вырезать" />
                                <ribbon:RibbonButton Content="Вставить" /><ribbon:RibbonButton Content="Дублировать" />
                                <ribbon:RibbonButton Content="Переместить" />
                            </ribbon:RibbonGroupBox>
                            -->
                        </ribbon:RibbonTab.Groups>
                    </ribbon:RibbonTab>

                    <ribbon:RibbonTab Header="Репозиторий">
                        <ribbon:RibbonTab.Groups>
                            <ribbon:RibbonGroupBox Header="Текущий репозиторий">
                                <StackPanel Spacing="2">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Наименование: " />
                                        <TextBlock Text="{Binding RepositoryExplorerVM.PhiladelphusRepositoryVM.Name}" />
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Состояние: " />
                                        <Rectangle Width="12" Height="12" Fill="{Binding RepositoryExplorerVM.PhiladelphusRepositoryVM.State, Converter={StaticResource stateToColorConverter}}" ToolTip.Tip="{Binding State, Converter={StaticResource enumDisplayAttributeConverter}, ConverterParameter=Description}" />
                                    </StackPanel>
                                </StackPanel>
                            </ribbon:RibbonGroupBox>
                            <ribbon:RibbonGroupBox Header="Текущий элемент">
                                <StackPanel Spacing="2">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Текущий элемент: " />
                                        <TextBlock Text="{Binding RepositoryExplorerVM.SelectedRepositoryMember.Name, FallbackValue='&lt;не выбран&gt;', TargetNullValue='&lt;не выбран&gt;'}" />
                                    </StackPanel>
                                    <ribbon:RibbonButton Content="Подробнее" Size="Medium" MinSize="Small" MaxSize="Large"
                                        Icon="{StaticResource IcoDetails}"
                                        Command="{Binding OpenRepositoryMemberDetailsWindowCommand}"  />
                                </StackPanel>
                            </ribbon:RibbonGroupBox>
                            <!-- Команды и иконки/подсказки — как в тулбаре обозревателя (RepositoryExplorerVM);
                                 CanExecute сам управляет доступностью по выбранному элементу. Размеры по
                                 общему правилу: Size=Medium (иконка слева + подпись), MinSize=Small
                                 (иконка-only при нехватке места), MaxSize=Large (иконка сверху + подпись).
                                 Иконка — Icon=ControlTemplate (тип IControlTemplate, не растр). -->
                            <ribbon:RibbonGroupBox Header="Иерархия репозитория">
                                <ribbon:RibbonButton Content="Добавить корень" Size="Medium" MinSize="Small" MaxSize="Large"
                                                     Icon="{StaticResource IcoRoot}"
                                                     Command="{Binding RepositoryExplorerVM.CreateRootCommand}"
                                                     ToolTip.Tip="Добавить корень" />
                                <ribbon:RibbonButton Content="Добавить узел" Size="Medium" MinSize="Small" MaxSize="Large"
                                                     Icon="{StaticResource IcoNode}"
                                                     Command="{Binding RepositoryExplorerVM.CreateNodeCommand}"
                                                     ToolTip.Tip="Добавить узел" />
                                <ribbon:RibbonButton Content="Добавить лист" Size="Medium" MinSize="Small" MaxSize="Large"
                                                     Icon="{StaticResource IcoLeave}"
                                                     Command="{Binding RepositoryExplorerVM.CreateLeaveCommand}"
                                                     ToolTip.Tip="Добавить лист" />
                                <ribbon:RibbonButton Content="Удалить элемент" Size="Medium" MinSize="Small" MaxSize="Large"
                                                     Icon="{StaticResource IcoDelete}"
                                                     Command="{Binding RepositoryExplorerVM.SoftDeleteRepositoryMemberCommand}"
                                                     ToolTip.Tip="Удалить выбранный элемент репозитория" />
                            </ribbon:RibbonGroupBox>
                            <ribbon:RibbonGroupBox Header="Атрибуты">
                                <ribbon:RibbonButton Content="Добавить атрибут" Size="Medium" MinSize="Small" MaxSize="Large"
                                                     Icon="{StaticResource IcoAdd}"
                                                     Command="{Binding RepositoryExplorerVM.CreateAttributeCommand}"
                                                     ToolTip.Tip="Добавить атрибут" />
                                <ribbon:RibbonButton Content="Удалить атрибут" Size="Medium" MinSize="Small" MaxSize="Large"
                                                     Icon="{StaticResource IcoRemove}"
                                                     Command="{Binding RepositoryExplorerVM.SoftDeleteRepositoryMemberAttributeCommand}"
                                                     ToolTip.Tip="Удалить атрибут" />
                            </ribbon:RibbonGroupBox>
                        </ribbon:RibbonTab.Groups>
                    </ribbon:RibbonTab>

                    <ribbon:RibbonTab Header="Формулы">
                        <ribbon:RibbonTab.Groups>
                            <ribbon:RibbonGroupBox Header="Редактор">
                                <ribbon:RibbonButton Content="Редактор формул"
                                                     Command="{Binding OpenFormulaEditorWindowCommand}"
                                                     CommandParameter="{Binding FormulaTestControlVM}"
                                                     Size="Medium" MinSize="Medium" MaxSize="Large" />
                            </ribbon:RibbonGroupBox>
                            <!-- Orientation="Horizontal": элементы кладём прямо в группу, ribbon сам
                                 раскладывает их в колонки (внутренний WrapPanel) и переносит. -->
                            <ribbon:RibbonGroupBox Header="Пересчет" Orientation="Horizontal" DataContext="{Binding RepositoryExplorerVM.FormulaBarVM}">
                                <StackPanel Spacing="2">
                                    <TextBlock Text="Пересчет формул" />
                                    <ComboBox ItemsSource="{Binding FormulaRecalculationModes}"
                                              SelectedItem="{Binding SelectedFormulaRecalculationMode}"
                                              MinWidth="180">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate><TextBlock Text="{Binding DisplayName}" /></DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>
                                </StackPanel>
                                <ribbon:RibbonButton Content="Пересчитать текущий"
                                        ToolTip.Tip="Пересчитать все формулы для текущего выбранного элемента репозитория."
                                        Size="Medium" MinSize="Medium" MaxSize="Large"
                                        Command="{Binding RecalculateCurrentFormulaCommand}" />
                                <ribbon:RibbonButton Content="Пересчитать все"
                                        ToolTip.Tip="Пересчитать все формулы для всех элементов репозитория."
                                        Size="Medium" MinSize="Medium" MaxSize="Large"
                                        Command="{Binding RecalculateAllFormulasCommand}" />
                            </ribbon:RibbonGroupBox>
                        </ribbon:RibbonTab.Groups>
                    </ribbon:RibbonTab>

                    <!--
                    <ribbon:RibbonTab Header="Вставка" /><ribbon:RibbonTab Header="Рассылки" />
                    -->

                    <ribbon:RibbonTab Header="Данные">
                        <ribbon:RibbonTab.Groups>
                            <!-- Кнопки операций — прямые элементы RibbonGroupBox (HeaderedItemsControl):
                                 лента сама раскладывает их WrapPanel'ом и переносит, не обрезая при росте списка. -->
                            <ribbon:RibbonGroupBox Header="Импорт" ItemsSource="{Binding ImportExportVM.ImportOperations}">
                                <ribbon:RibbonGroupBox.ItemTemplate>
                                    <DataTemplate><ribbon:RibbonButton Content="{Binding Label}" Command="{Binding Command}" Size="Medium" MinSize="Medium" MaxSize="Large" /></DataTemplate>
                                </ribbon:RibbonGroupBox.ItemTemplate>
                            </ribbon:RibbonGroupBox>
                            <ribbon:RibbonGroupBox Header="Экспорт" ItemsSource="{Binding ImportExportVM.ExportOperations}">
                                <ribbon:RibbonGroupBox.ItemTemplate>
                                    <DataTemplate><ribbon:RibbonButton Content="{Binding Label}" Command="{Binding Command}" Size="Medium" MinSize="Medium" MaxSize="Large" /></DataTemplate>
                                </ribbon:RibbonGroupBox.ItemTemplate>
                            </ribbon:RibbonGroupBox>
                            <ribbon:RibbonGroupBox Header="Конвертация" ItemsSource="{Binding ImportExportVM.ConversionOperations}">
                                <ribbon:RibbonGroupBox.ItemTemplate>
                                    <DataTemplate><ribbon:RibbonButton Content="{Binding Label}" Command="{Binding Command}" Size="Medium" MinSize="Medium" MaxSize="Large" /></DataTemplate>
                                </ribbon:RibbonGroupBox.ItemTemplate>
                            </ribbon:RibbonGroupBox>
                            <ribbon:RibbonGroupBox Header="Прогресс">
                                <StackPanel Spacing="2">
                                    <TextBlock Text="{Binding ImportExportVM.CurrentProcess}" />
                                    <TextBlock Text="{Binding ImportExportVM.CurrentProgress}" />
                                </StackPanel>
                            </ribbon:RibbonGroupBox>
                        </ribbon:RibbonTab.Groups>
                    </ribbon:RibbonTab>

                    <ribbon:RibbonTab Header="Вид">
                        <ribbon:RibbonTab.Groups>
                            <!-- DataContext задаётся на группе, а не на RibbonTab: Ribbon.Avalonia
                                 выносит группы выбранной вкладки в свой контент, поэтому DataContext
                                 с RibbonTab до групп не наследуется (ср. рабочая вкладка «Формулы»→«Пересчет»). -->
                            <ribbon:RibbonGroupBox Header="Тема" DataContext="{Binding ThemeSettingsVM}">
                                <StackPanel Spacing="2">
                                    <TextBlock Text="Тема оформления" />
                                    <ComboBox ItemsSource="{Binding Modes}"
                                              SelectedItem="{Binding SelectedMode}"
                                              MinWidth="160">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding DisplayName}" />
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>
                                </StackPanel>
                            </ribbon:RibbonGroupBox>
                        </ribbon:RibbonTab.Groups>
                    </ribbon:RibbonTab>

                    <ribbon:RibbonTab Header="Расширения">
                        <ribbon:RibbonTab.Groups>
                            <!-- DataContext задаётся на группах, а не на RibbonTab: Ribbon.Avalonia выносит
                                 группы выбранной вкладки в свой контент, поэтому DataContext с RibbonTab
                                 до них не наследуется (ср. рабочие вкладки «Вид» и «Формулы»). -->
                            <ribbon:RibbonGroupBox Header="Текущее расширение" Orientation="Horizontal" DataContext="{Binding ExtensionsControlVM}">
                                <StackPanel Spacing="2">
                                    <ComboBox ItemsSource="{Binding Extensions}" SelectedItem="{Binding SelectedExtension}" Width="200">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate><TextBlock Text="{Binding Name}" /></DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Состояние: " />
                                        <TextBlock Text="{Binding SelectedExtension.State}" />
                                    </StackPanel>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <ribbon:RibbonButton Content="Запустить" Size="Medium" MinSize="Medium" MaxSize="Large" Command="{Binding StartExtensionCommand}" />
                                    <ribbon:RibbonButton Content="Остановить" Size="Medium" MinSize="Medium" MaxSize="Large" Command="{Binding StopExtensionCommand}" />
                                </StackPanel>
                                <ribbon:RibbonButton Content="Выполнить" Size="Medium" MinSize="Medium" MaxSize="Large" Command="{Binding ExecuteExtensionCommand}" />
                                <ribbon:RibbonToggleButton Content="Окно" Command="{Binding OpenMainWindowCommand}" IsChecked="{Binding SelectedExtension.Window.IsVisible, Mode=OneWay}" />
                            </ribbon:RibbonGroupBox>
                            <ribbon:RibbonGroupBox Header="Виджеты расширений" DataContext="{Binding ExtensionsControlVM}">
                                <ContentControl Content="{Binding SelectedExtension.RibbonWidget}" />
                            </ribbon:RibbonGroupBox>
                            <!-- <ribbon:RibbonGroupBox Header="Окна расширений" /> -->
                        </ribbon:RibbonTab.Groups>
                    </ribbon:RibbonTab>

                    <!--
                    <ribbon:RibbonTab Header="Администрирование" /><ribbon:RibbonTab Header="Настройки" />
                    <ribbon:RibbonTab Header="Справка"><ribbon:RibbonTab.Groups>
                        <ribbon:RibbonGroupBox><ribbon:RibbonButton Content="О нас" /></ribbon:RibbonGroupBox>
                    </ribbon:RibbonTab.Groups></ribbon:RibbonTab>
                    -->
                </ribbon:Ribbon.Tabs>
            </ribbon:Ribbon>

            <!-- ===== Основная компоновка ===== -->
            <Grid RowDefinitions="4*,Auto,Auto,Auto,0">
                <Grid Grid.Row="0" ColumnDefinitions="Auto,Auto,5*">
                    <!-- Навигационная панель (адаптация закомментированного в WPF Expander ExpandDirection=Left):
                         сворачивается ToggleButton + LayoutTransformControl (как в LaunchWindow), списки статические. -->
                    <Grid Grid.Column="0" Margin="1" ColumnDefinitions="Auto,Auto">
                        <ToggleButton Grid.Column="1" x:Name="navToggle" IsChecked="False" VerticalAlignment="Stretch" Padding="2,8">
                            <LayoutTransformControl>
                                <LayoutTransformControl.LayoutTransform>
                                    <RotateTransform Angle="-90" />
                                </LayoutTransformControl.LayoutTransform>
                                <TextBlock Text="Навигационная панель" />
                            </LayoutTransformControl>
                        </ToggleButton>
                        <ctrls:NavigationPanel Grid.Column="0" Width="260"
                                               IsVisible="{Binding #navToggle.IsChecked}" />
                    </Grid>

                    <GridSplitter Grid.Column="1" Width="3" HorizontalAlignment="Center" VerticalAlignment="Stretch" />

                    <HeaderedContentControl Grid.Column="2" Header="Рабочая область">
                        <TabControl Classes="compact">
                            <TabItem Classes="compact" Header="Репозиторий">
                                <re:RepositoryExplorer DataContext="{Binding RepositoryExplorerVM}" />
                            </TabItem>
                            <TabItem Classes="compact" Header="Отчеты">
                                <ctrls:ReportProcessor DataContext="{Binding ReportsControlVM}" />
                            </TabItem>
                            <!--
                            <TabItem Header="Настраиваемый отчет"><ctrls:CustomizableReport /></TabItem>
                            -->
                            <TabItem Classes="compact" Header="Настройки">
                                <ctrls:ApplicationSettings DataContext="{Binding ApplicationSettingsControlVM}" />
                            </TabItem>
                        </TabControl>
                    </HeaderedContentControl>
                </Grid>

                <ctrls:MessageLog Grid.Row="1" DataContext="{Binding MainWindowNotificationsVM.MessageLogControlVM}" />

                <Grid Grid.Row="2" ColumnDefinitions="*,320" MaxHeight="350">
                    <StackPanel x:Name="popupTarget" Grid.Column="1" />
                </Grid>

                <!-- Замена WPF StatusBar (в Avalonia нет StatusBar): рамка со строкой статуса. -->
                <Border Grid.Row="3" BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}" BorderThickness="0,1,0,0" Padding="6,2">
                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <TextBlock Grid.Column="0" Text="{Binding UserName}" />
                        <TextBlock Grid.Column="2" Text="{Binding AssemblyVersion}" HorizontalAlignment="Right" />
                    </Grid>
                </Border>

                <ProgressBar Grid.Row="4" Minimum="0" Maximum="100" Value="{Binding CurrentProgress}" Height="3" />
            </Grid>
        </DockPanel>
    </Grid>
</Window>

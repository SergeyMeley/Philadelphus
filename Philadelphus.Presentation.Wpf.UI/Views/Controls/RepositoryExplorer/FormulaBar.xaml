<UserControl x:Class="Philadelphus.Presentation.Wpf.UI.Views.Controls.RepositoryExplorer.FormulaBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:behaviors="clr-namespace:Philadelphus.Presentation.Wpf.UI.Behaviors"
             mc:Ignorable="d"
             d:DesignHeight="30"
             d:DesignWidth="800">
    <Border BorderBrush="LightGray"
            BorderThickness="0,0,0,1"
            Padding="2"
            Margin="0,0,0,2"
            Background="#FFF7F7F7">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="160" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBox Grid.Row="0"
                     Grid.Column="0"
                     Text="{Binding FormulaBarAddress, Mode=OneWay}"
                     IsReadOnly="True"
                     Height="25"
                     Margin="1"
                     VerticalContentAlignment="Center"
                     Background="White"
                     ToolTip="Адрес ячейки" />
            <Button Grid.Row="0"
                    Grid.Column="1"
                    Content="{StaticResource imageApproval64}"
                    Command="{Binding ApplyFormulaBarCommand}"
                    Height="25"
                    Width="25"
                    Margin="1"
                    Background="Transparent"
                    ToolTip="Применить формулу" />
            <Button Grid.Row="0"
                    Grid.Column="2"
                    Content="{StaticResource imageReturn}"
                    Command="{Binding CancelFormulaBarCommand}"
                    Height="25"
                    Width="25"
                    Margin="1"
                    Background="Transparent"
                    ToolTip="Отменить редактирование формулы" />
            <Button Grid.Row="0"
                    Grid.Column="3"
                    Content="{StaticResource imageOpen}"
                    Command="{Binding OpenFormulaEditorFromFormulaBarCommand}"
                    Height="25"
                    Width="25"
                    Margin="1"
                    Background="Transparent"
                    ToolTip="Открыть редактор формул" />
            <Grid Grid.Row="0"
                  Grid.Column="4"
                  Height="25"
                  Margin="1"
                  Background="White">
                <Border BorderBrush="#FFABADB3"
                        BorderThickness="1" />
                <ItemsControl Margin="5,0,4,0"
                              VerticalAlignment="Center"
                              IsHitTestVisible="False"
                              ItemsSource="{Binding FormulaHighlightSegments}"
                              Panel.ZIndex="1">
                    <ItemsControl.Style>
                        <Style TargetType="ItemsControl">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsFormulaHighlightOpen}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ItemsControl.Style>
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock FontFamily="Consolas"
                                       FontSize="13"
                                       Text="{Binding Text}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#2B2B2B" />
                                        <Setter Property="Background" Value="Transparent" />
                                        <Setter Property="FontWeight" Value="Normal" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Kind}" Value="Function">
                                                <Setter Property="Foreground" Value="#005A9E" />
                                                <Setter Property="FontWeight" Value="SemiBold" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Kind}" Value="Identifier">
                                                <Setter Property="Foreground" Value="#6A4C00" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Kind}" Value="Number">
                                                <Setter Property="Foreground" Value="#098658" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Kind}" Value="String">
                                                <Setter Property="Foreground" Value="#A31515" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Kind}" Value="TreeLeaveReference">
                                                <Setter Property="Foreground" Value="#795E26" />
                                                <Setter Property="FontWeight" Value="SemiBold" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Kind}" Value="Parenthesis">
                                                <Setter Property="Foreground" Value="#5C2D91" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Kind}" Value="Punctuation">
                                                <Setter Property="Foreground" Value="#666666" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Kind}" Value="Operator">
                                                <Setter Property="Foreground" Value="#AF00DB" />
                                                <Setter Property="FontWeight" Value="SemiBold" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Kind}" Value="Error">
                                                <Setter Property="Foreground" Value="#B00020" />
                                                <Setter Property="Background" Value="#FFE5E5" />
                                                <Setter Property="TextDecorations" Value="Underline" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsMatchingParenthesis}" Value="True">
                                                <Setter Property="Background" Value="#D7ECFF" />
                                                <Setter Property="FontWeight" Value="Bold" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <TextBox x:Name="FormulaTextBox"
                         Text="{Binding FormulaBarText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         IsEnabled="{Binding IsFormulaBarEnabled}"
                         behaviors:FormulaSuggestionTextBoxBehavior.IsEnabled="True"
                         behaviors:FormulaSuggestionTextBoxBehavior.SuggestionsListBox="{Binding ElementName=FormulaSuggestionsListBox}"
                         behaviors:FormulaBarTextBoxBehavior.Track="True"
                         behaviors:FormulaBarTextBoxBehavior.IsEditing="{Binding IsFormulaBarEditing, Mode=TwoWay}"
                         behaviors:FormulaBarTextBoxBehavior.CaretIndex="{Binding FormulaBarCaretIndex, Mode=TwoWay}"
                         behaviors:FormulaBarTextBoxBehavior.SelectionStart="{Binding FormulaBarSelectionStart, Mode=TwoWay}"
                         behaviors:FormulaBarTextBoxBehavior.SelectionLength="{Binding FormulaBarSelectionLength, Mode=TwoWay}"
                         BorderThickness="0"
                         Background="Transparent"
                         CaretBrush="Black"
                         FontFamily="Consolas"
                         FontSize="13"
                         Padding="4,0,4,0"
                         VerticalContentAlignment="Center"
                         Panel.ZIndex="2">
                    <TextBox.Style>
                        <Style TargetType="TextBox">
                            <Setter Property="Foreground" Value="Black" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsFormulaHighlightOpen}" Value="True">
                                    <Setter Property="Foreground" Value="Transparent" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBox.Style>
                    <TextBox.InputBindings>
                        <KeyBinding Key="Enter" Command="{Binding ApplyFormulaBarCommand}" />
                        <KeyBinding Key="Escape" Command="{Binding CancelFormulaBarCommand}" />
                    </TextBox.InputBindings>
                </TextBox>
            </Grid>
            <Popup Grid.Row="0"
                   Grid.Column="4"
                   AllowsTransparency="True"
                   IsOpen="{Binding IsFormulaSuggestionsOpen}"
                   Placement="Bottom"
                   PlacementTarget="{Binding ElementName=FormulaTextBox}"
                   PopupAnimation="Fade"
                   StaysOpen="False">
                <Border MinWidth="{Binding ActualWidth, ElementName=FormulaTextBox}"
                        MaxWidth="520"
                        MaxHeight="260"
                        Background="White"
                        BorderBrush="#8A8A8A"
                        BorderThickness="1"
                        Padding="2">
                    <ListBox x:Name="FormulaSuggestionsListBox"
                             ItemsSource="{Binding FormulaSuggestions}"
                             SelectedItem="{Binding SelectedFormulaSuggestion, Mode=TwoWay}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="4,3">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Row="0"
                                               Grid.Column="0"
                                               FontWeight="SemiBold"
                                               Text="{Binding DisplayName}" />
                                    <TextBlock Grid.Row="0"
                                               Grid.Column="1"
                                               Margin="12,0,0,0"
                                               Foreground="Gray"
                                               Text="{Binding Category}" />
                                    <TextBlock Grid.Row="1"
                                               Grid.Column="0"
                                               Grid.ColumnSpan="2"
                                               Foreground="DimGray"
                                               Text="{Binding Signature}"
                                               TextTrimming="CharacterEllipsis" />
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Border>
            </Popup>
            <Border Grid.Row="1"
                    Grid.Column="4"
                    Margin="1,2,1,0"
                    Padding="8,5"
                    Background="#FFF8E7"
                    BorderBrush="#D8B75A"
                    BorderThickness="1">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsFormulaSignatureHelpOpen}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel>
                    <TextBlock FontWeight="SemiBold"
                               Text="{Binding FormulaSignatureText}"
                               TextTrimming="CharacterEllipsis" />
                    <TextBlock Margin="0,2,0,0"
                               Foreground="DimGray"
                               Text="{Binding FormulaActiveArgumentText}"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</UserControl>

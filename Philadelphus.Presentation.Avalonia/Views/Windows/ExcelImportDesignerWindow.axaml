<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Philadelphus.Presentation.Avalonia.Views.Windows.ExcelImportDesignerWindow"
        Title="Импорт дерева"
        Width="1400"
        Height="980"
        WindowStartupLocation="CenterScreen">
    <!-- Каркас. Конструктор импорта (DataGrid + диаграмма связей) переносится из WPF инкрементально. -->
    <Grid>
        <TextBlock Text="ExcelImportDesignerWindow (Avalonia) — каркас"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Opacity="0.5" />
    </Grid>
</Window>

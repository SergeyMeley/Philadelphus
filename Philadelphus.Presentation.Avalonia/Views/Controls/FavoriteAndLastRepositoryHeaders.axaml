<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:lbs="clr-namespace:Philadelphus.Presentation.Avalonia.Views.Controls.CollectionControls.ListBoxes"
             xmlns:detail="clr-namespace:Philadelphus.Presentation.Avalonia.Views.Controls.DetailedInformationGrids"
             x:Class="Philadelphus.Presentation.Avalonia.Views.Controls.FavoriteAndLastRepositoryHeaders">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="2*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <CheckBox Grid.Row="0" Grid.Column="0"
                  Content="Отобразить скрытые"
                  IsChecked="{Binding RepositoryHeadersCollectionVM.ShowHiddenRepositoryHeaders, Mode=TwoWay}"
                  Margin="4,2,4,2"
                  HorizontalAlignment="Left" />

        <HeaderedContentControl Grid.Row="1" Grid.Column="0" Header="Избранные">
            <lbs:RepositoryHeadersListBox
                RepositoryHeadersItemsSource="{Binding RepositoryHeadersCollectionVM.FavoritePhiladelphusRepositoryHeadersVMs}"
                RepositoryHeadersSelectedItem="{Binding RepositoryHeadersCollectionVM.SelectedPhiladelphusRepositoryHeaderVM, Mode=TwoWay}" />
        </HeaderedContentControl>
        <HeaderedContentControl Grid.Row="2" Grid.Column="0" Header="Недавние">
            <lbs:RepositoryHeadersListBox
                RepositoryHeadersItemsSource="{Binding RepositoryHeadersCollectionVM.LastPhiladelphusRepositoryHeadersVMs}"
                RepositoryHeadersSelectedItem="{Binding RepositoryHeadersCollectionVM.SelectedPhiladelphusRepositoryHeaderVM, Mode=TwoWay}" />
        </HeaderedContentControl>

        <Grid Grid.Row="0" Grid.Column="1" Grid.RowSpan="3" ColumnDefinitions="Auto,Auto">
            <ToggleButton Grid.Column="0" x:Name="favDetailToggle" VerticalAlignment="Stretch" Padding="2,8">
                <LayoutTransformControl>
                    <LayoutTransformControl.LayoutTransform>
                        <RotateTransform Angle="-90" />
                    </LayoutTransformControl.LayoutTransform>
                    <TextBlock Text="Детальная информация" />
                </LayoutTransformControl>
            </ToggleButton>
            <detail:UniversalDetails Grid.Column="1"
                                     IsVisible="{Binding #favDetailToggle.IsChecked}"
                                     DataContext="{Binding RepositoryHeadersCollectionVM.SelectedPhiladelphusRepositoryHeaderVM}" />
        </Grid>

        <Button Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="100" Content="Выбрать и начать работу!" Command="{Binding OpenMainWindowWithHeaderCommand}" />
    </Grid>
</UserControl>
